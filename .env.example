APP_NAME=livecopilot
LOG_LEVEL=INFO
MAX_CONTEXT_TURNS=8
SUGGESTIONS_LIMIT=4
FILLERS_LIMIT=4
QUICK_REPLIES_LIMIT=4
CAPTURE_MODE=mock
TRANSCRIPTION_PROVIDER=external
TRANSCRIPTION_PREFERENCE=
LOCAL_ASR_ENABLED=false
LOCAL_ASR_TIMEOUT_MS=1200
TRANSCRIPTION_LOCAL_ENABLED=false
TRANSCRIPTION_LOCAL_MODEL=local-asr-baseline
TRANSCRIPTION_EXTERNAL_MODEL=gpt-4o-mini
VOICE_OUTPUT_ENABLED=false
VOICE_OUTPUT_PROVIDER=external
VOICE_OUTPUT_MODEL=gpt-4o-mini-tts
DOWNLOADS_WATCH_DIR=~/Downloads
DOWNLOADS_IMPORT_MODE=copy
DOWNLOADS_NORMALIZE_NAMES=true
DOWNLOADS_TRIGGER_INGEST=true
MIKROTIK_BASE_URL=https://IP_DO_MIKROTIK/rest
MIKROTIK_USERNAME=livecopilot_ro
MIKROTIK_PASSWORD=
MIKROTIK_VERIFY_TLS=false
MIKROTIK_TIMEOUT=5
