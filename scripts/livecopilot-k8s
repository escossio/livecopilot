    if format_style == "compact":
        print(f"{intent}: {explanation}")
        return

    print("LiveCopilot K8s (explain)")
    print("nao executa comandos no cluster; apenas sugere.")
    print(f"\nPergunta: {query}")
    print(f"Intencao: {intent}")
    print(f"Explicacao: {explanation}")


def _render_commands(query: str, commands: list[str], format_style: str) -> None:
    if format_style == "compact":
        for cmd in commands[:8]:
            print(cmd)
        return

    print("LiveCopilot K8s (commands)")
    print("nao executa comandos no cluster; apenas sugere.")
    print(f"\nPergunta: {query}")
    print("Comandos sugeridos:")
    for cmd in commands[:8]:
        print(cmd)


def _render_sources(query: str, context: str, results: list[dict], format_style: str) -> None:
    if format_style == "compact":
        if not results:
            print("(nenhuma fonte)")
            return
        for item in results[:3]:
            source = item.get("source_file", "")
            title = str(item.get("title", "") or "").strip()
            title = title if len(title) <= 80 else title[:80] + "..."
            print(f"- {source} | {title or '(sem titulo)'}")
        return

    print("LiveCopilot K8s (sources)")
    print("nao executa comandos no cluster; apenas sugere.")
    print(f"\nPergunta: {query}")
    if context.strip():
        ctx = re.sub(r"\s+", " ", context).strip()
        if len(ctx) > 320:
            ctx = ctx[:320] + "..."
        print(f"Resumo do contexto: {ctx}")
    else:
        print("Resumo do contexto: (vazio)")

    print("\nTop fontes:")
    if not results:
        print("- (nenhum resultado semantico)")
        return

    for i, item in enumerate(results[:5], start=1):
        similarity = item.get("similarity")
        source = item.get("source_file", "")
        title = str(item.get("title", "") or "").strip()
        snippet = str(item.get("snippet", "") or "").strip()
        title = title if len(title) <= 100 else title[:100] + "..."
        snippet = re.sub(r"\s+", " ", snippet)
        snippet = snippet if len(snippet) <= 140 else snippet[:140] + "..."
        print(f"{i}. sim={similarity} | source={source}")
        print(f"   title: {title}")
        print(f"   snippet: {snippet or '(sem snippet)'}")


def _take_matching(commands: list[str], used: set[str], patterns: list[str], limit: int = 2) -> list[str]:
    picked: list[str] = []
    for cmd in commands:
        key = cmd.strip().lower()
        if key in used:
            continue
        for pat in patterns:
            if re.search(pat, key):
                used.add(key)
                picked.append(cmd)
                break
        if len(picked) >= limit:
            break
    return picked


def _build_diagnosis_steps(intent: str, commands: list[str]) -> list[dict]:
    used: set[str] = set()

    if "crashloop" in intent.lower() or "debug de pod" in intent.lower():
        steps = [
            {
                "step": 1,
                "title": "Confirmar estado do pod",
                "commands": _take_matching(commands, used, [r"get pods?", r"describe pod"], limit=2),
                "reason": "Verificar status, restarts e sinais iniciais antes de aprofundar.",
            },
            {
                "step": 2,
                "title": "Coletar logs atuais e anteriores",
                "commands": _take_matching(commands, used, [r"\blogs?\b", r"--previous"], limit=3),
                "reason": "Comparar falha atual com a execucao anterior para identificar padrao.",
            },
            {
                "step": 3,
                "title": "Correlacionar com eventos",
                "commands": _take_matching(commands, used, [r"get events?", r"describe pod"], limit=2),
                "reason": "Eventos ajudam a localizar causa provavel (imagem, probes, OOM, permissao).",
            },
        ]
    elif "eventos" in intent.lower():
        steps = [
            {
                "step": 1,
                "title": "Listar eventos recentes",
                "commands": _take_matching(commands, used, [r"get events?"], limit=2),
                "reason": "Ordenar por tempo para achar o primeiro erro relevante.",
            },
            {
                "step": 2,
                "title": "Inspecionar pod afetado",
                "commands": _take_matching(commands, used, [r"describe pod", r"get pods?"], limit=2),
                "reason": "Relacionar eventos com status real do pod e condicoes de container.",
            },
            {
                "step": 3,
                "title": "Validar evidencias em logs",
                "commands": _take_matching(commands, used, [r"\blogs?\b"], limit=2),
                "reason": "Confirmar se a mensagem de erro do evento aparece no container.",
            },
        ]
    elif "restart" in intent.lower() and "deployment" in intent.lower():
        steps = [
            {
                "step": 1,
                "title": "Checar estado atual do deployment",
                "commands": _take_matching(commands, used, [r"get deploy", r"describe deploy", r"get pods?"], limit=2),
                "reason": "Estabelecer baseline antes de qualquer acao de restart.",
            },
            {
                "step": 2,
                "title": "Executar restart controlado",
                "commands": _take_matching(commands, used, [r"rollout restart"], limit=1),
                "reason": "Reiniciar rollout mantendo rastreabilidade da mudanca.",
            },
            {
                "step": 3,
                "title": "Acompanhar rollout e saude",
                "commands": _take_matching(commands, used, [r"rollout status", r"get pods?", r"describe pod"], limit=3),
                "reason": "Confirmar progresso do rollout e detectar falhas rapidamente.",
            },
        ]
    else:
        steps = [
            {
                "step": 1,
                "title": "Mapear estado atual",
                "commands": _take_matching(commands, used, [r"get ", r"describe "], limit=3),
                "reason": "Levantar o estado do recurso e sinais de erro mais visiveis.",
            },
            {
                "step": 2,
                "title": "Aprofundar evidencia tecnica",
                "commands": _take_matching(commands, used, [r"\blogs?\b", r"get events?", r"describe "], limit=3),
                "reason": "Cruzar eventos e logs para reduzir hipoteses.",
            },
            {
                "step": 3,
                "title": "Revalidar apos a analise",
                "commands": _take_matching(commands, used, [r"rollout status", r"get ", r"describe "], limit=3),
                "reason": "Rechecar estado para confirmar se o problema persiste.",
            },
        ]

    if "crashloop" in intent.lower() or "debug de pod" in intent.lower():
        fallback_by_step = {
            1: ["kubectl describe pod <pod>"],
            2: ["kubectl logs <pod> --previous"],
            3: ["kubectl get events --sort-by=.lastTimestamp"],
        }
    elif "eventos" in intent.lower():
        fallback_by_step = {
            1: ["kubectl get events --sort-by=.lastTimestamp"],
            2: ["kubectl describe pod <pod>"],
            3: ["kubectl logs <pod> -c <container> --previous"],
        }
    elif "restart" in intent.lower() and "deployment" in intent.lower():
        fallback_by_step = {
            1: ["kubectl get deployment <nome>"],
            2: ["kubectl rollout restart deployment <nome>"],
            3: ["kubectl rollout status deployment <nome>"],
        }
    else:
        fallback_by_step = {}

    for step in steps:
        if step["commands"]:
            continue
        default_cmds = fallback_by_step.get(step["step"], [])
        for cmd in default_cmds:
            key = cmd.strip().lower()
            if key in used:
                continue
            used.add(key)
            step["commands"] = [cmd]
            break
        if step["commands"]:
            continue
        for cmd in commands:
            key = cmd.strip().lower()
            if key in used:
                continue
            used.add(key)
            step["commands"] = [cmd]
            break

    return steps


def _render_diagnose(query: str, intent: str, explanation: str, commands: list[str], results: list[dict], format_style: str) -> None:
    steps = _build_diagnosis_steps(intent=intent, commands=commands)
    if format_style == "compact":
        print(f"Diagnose: {intent}")
        print(explanation)
        for item in steps:
            step_cmds = "; ".join(item["commands"][:2]) if item["commands"] else "(sem comandos)"
            print(f"{item['step']}. {item['title']}: {step_cmds}")
        return

    print("LiveCopilot K8s (diagnose)")
    print("nao executa comandos no cluster; apenas orienta diagnostico.")
    print(f"\nPergunta: {query}")
    print(f"Intencao detectada: {intent}")
    print(f"Resumo curto: {explanation}")
    print("\nChecklist de diagnostico:")
    for item in steps:
        print(f"{item['step']}. {item['title']}")
        print(f"   motivo: {item['reason']}")
        if item["commands"]:
            print("   comandos:")
            for cmd in item["commands"]:
                print(f"   - {cmd}")
        else:
            print("   comandos: (nenhum comando sugerido)")

    print("\nFontes resumidas:")
    if not results:
        print("- (nenhum resultado semantico)")
    else:
        for item in results[:3]:
            source = item.get("source_file", "")
            title = re.sub(r"\s+", " ", str(item.get("title", "") or "").strip())
            if len(title) > 90:
                title = title[:90] + "..."
            print(f"- {source} | {title or '(sem titulo)'}")


def _build_plan_goal(intent: str, explanation: str) -> str:
    lowered = intent.lower()
    if "debug de pod" in lowered or "crashloop" in lowered:
        return "Identificar causa raiz do pod e coletar evidencias tecnicas para correção."
    if "eventos" in lowered:
        return "Localizar rapidamente o erro dominante nos eventos do pod/namespace."
    if "restart de deployment" in lowered:
        return "Executar restart controlado e confirmar saude do rollout."
    if "namespace" in lowered:
        return "Criar e validar namespace alvo antes das próximas ações."
    if "serviceaccount" in lowered:
        return "Gerar token de ServiceAccount com escopo correto e validar uso."
    return explanation


def _build_plan_steps(intent: str, commands: list[str]) -> list[dict]:
    diagnosis_steps = _build_diagnosis_steps(intent=intent, commands=commands)
    steps: list[dict] = []
    for item in diagnosis_steps[:5]:
        step_cmds = item.get("commands") if isinstance(item.get("commands"), list) else []
        steps.append(
            {
                "step": int(item.get("step", len(steps) + 1)),
                "title": str(item.get("title", "Passo operacional")),
                "commands": [str(c) for c in step_cmds[:2]],
                "notes": str(item.get("reason", "Validar resultado antes de seguir para o próximo passo.")),
            }
        )
    return steps


def _render_plan(query: str, intent: str, goal: str, plan_steps: list[dict], format_style: str) -> None:
    if format_style == "compact":
        print(f"Plano: {intent}")
        print(f"Objetivo: {goal}")
        for step in plan_steps[:5]:
            cmds = step.get("commands", [])
            cmd_text = " | ".join(cmds[:2]) if isinstance(cmds, list) and cmds else "(sem comando)"
            print(f"{step.get('step')}. {step.get('title')}: {cmd_text}")
        return

    print("LiveCopilot K8s (plan)")
    print("nao executa comandos no cluster; apenas orienta plano operacional.")
    print(f"\nPergunta: {query}")
    print(f"Intencao detectada: {intent}")
    print(f"Objetivo: {goal}")
    print("\nPlano de acao:")
    for step in plan_steps[:5]:
        print(f"{step.get('step')}. {step.get('title')}")
        cmds = step.get("commands", [])
        if isinstance(cmds, list) and cmds:
            for cmd in cmds[:2]:
                print(f"   - {cmd}")
        else:
            print("   - (sem comando sugerido)")
        note = str(step.get("notes", "") or "").strip()
        if note:
            print(f"   obs: {note}")

    print("\nObservacao de seguranca:")
    print("- Revise namespace/recurso alvo e execute passo a passo; nao aplicar tudo em bloco sem validar saida.")


def _build_runbook_title(intent: str) -> str:
    lowered = intent.lower()
    if "debug de pod" in lowered or "crashloop" in lowered:
        return "Runbook Operacional: CrashLoopBackOff de Pod"
    if "eventos" in lowered:
        return "Runbook Operacional: Diagnostico por Eventos de Pod"
    if "restart de deployment" in lowered:
        return "Runbook Operacional: Restart Controlado de Deployment"
    if "namespace" in lowered:
        return "Runbook Operacional: Criacao de Namespace"
    if "serviceaccount" in lowered:
        return "Runbook Operacional: Token de ServiceAccount"
    return "Runbook Operacional Kubernetes"


def _build_runbook_sections(intent: str, commands: list[str]) -> tuple[list[str], list[str], list[str], list[str]]:
    steps = _build_plan_steps(intent=intent, commands=commands)
    prechecks: list[str] = []
    recommended: list[str] = []
    validation: list[str] = []
    notes: list[str] = []

    if steps:
        first_cmds = [str(c) for c in steps[0].get("commands", []) if str(c).strip()]
        prechecks = first_cmds[:2]
        for item in steps:
            for cmd in item.get("commands", []):
                cmd_s = str(cmd).strip()
                if cmd_s and cmd_s not in recommended:
                    recommended.append(cmd_s)
        for item in steps[1:]:
            for cmd in item.get("commands", []):
                cmd_s = str(cmd).strip()
                if cmd_s and (("status" in cmd_s) or ("get " in cmd_s) or ("describe " in cmd_s)):
                    if cmd_s not in validation:
                        validation.append(cmd_s)
    if not prechecks:
        prechecks = commands[:2]
    if not recommended:
        recommended = commands[:5]
    if not validation:
        validation = commands[:2]

    lowered = intent.lower()
    if "restart de deployment" in lowered:
        notes = [
            "Verifique namespace e nome do deployment antes do restart.",
            "Acompanhe rollout e interrompa se houver degradacao.",
        ]
    elif "crashloop" in lowered or "debug de pod" in lowered:
        notes = [
            "Priorize logs com --previous para capturar a falha anterior.",
            "Nao aplique mudancas sem confirmar causa nos eventos/logs.",
        ]
    else:
        notes = [
            "Execute em ordem e valide a saida a cada etapa.",
            "Revise escopo de namespace/recurso antes de comandos destrutivos.",
        ]

    return prechecks[:3], recommended[:8], validation[:4], notes[:3]


def _render_runbook(
    query: str,
    intent: str,
    title: str,
    goal: str,
    prechecks: list[str],
    commands: list[str],
    validation: list[str],
    notes: list[str],
    format_style: str,
) -> None:
    if format_style == "compact":
        print(title)
        print(f"Objetivo: {goal}")
        for cmd in commands[:4]:
            print(cmd)
        return

    print("LiveCopilot K8s (runbook)")
    print("nao executa comandos no cluster; apenas orienta procedimento operacional.")
    print(f"\nTitulo: {title}")
    print(f"Pergunta: {query}")
    print(f"Intencao: {intent}")
    print(f"Objetivo: {goal}")

    print("\nPre-checagens:")
    for item in prechecks[:3]:
        print(f"- {item}")

    print("\nComandos recomendados:")
    for cmd in commands[:8]:
        print(f"- {cmd}")

    print("\nValidacao pos-acao:")
    for item in validation[:4]:
        print(f"- {item}")

    print("\nObservacoes:")
    for note in notes[:3]:
        print(f"- {note}")


def _build_sources(results: list[dict], limit: int = 5) -> list[dict]:
    out: list[dict] = []
    for item in results[:limit]:
        title = str(item.get("title", "") or "").strip()
        snippet = re.sub(r"\s+", " ", str(item.get("snippet", "") or "").strip())
        out.append(
            {
                "similarity": item.get("similarity"),
                "source_file": item.get("source_file", ""),
                "title": title,
                "snippet": snippet,
            }
        )
    return out


def _json_ok_payload(
    *,
    mode: str,
    format_style: str,
    query: str,
    intent: str,
    explanation: str,
    commands: list[str],
    results: list[dict],
    context: str,
    targets: dict[str, str],
    input_mode: str | None,
) -> dict:
    if mode == "runbook":
        goal = _build_plan_goal(intent=intent, explanation=explanation)
        title = _build_runbook_title(intent=intent)
        prechecks, recommended, validation, notes = _build_runbook_sections(intent=intent, commands=commands)
        payload = {
            "status": "ok",
            "mode": mode,
            "query": query,
            "intent": intent,
            "title": title,
            "goal": goal,
            "prechecks": prechecks,
            "commands": recommended,
            "validation": validation,
            "notes": notes,
            "sources": _build_sources(results, limit=5),
            "context": context or "",
        }
        if targets:
            payload["targets"] = targets
        if input_mode:
            payload["input_mode"] = input_mode
        return payload
    if mode == "plan":
        goal = _build_plan_goal(intent=intent, explanation=explanation)
        payload = {
            "status": "ok",
            "mode": mode,
            "query": query,
            "intent": intent,
            "goal": goal,
            "plan_steps": _build_plan_steps(intent=intent, commands=commands),
            "sources": _build_sources(results, limit=5),
            "context": context or "",
        }
        if targets:
            payload["targets"] = targets
        if input_mode:
            payload["input_mode"] = input_mode
        return payload
    if mode == "diagnose":
        payload = {
            "status": "ok",
            "mode": mode,
            "format": format_style,
            "query": query,
            "intent": intent,
            "diagnosis_steps": _build_diagnosis_steps(intent=intent, commands=commands),
            "sources": _build_sources(results, limit=5),
            "context": context or "",
        }
        if targets:
            payload["targets"] = targets
        if input_mode:
            payload["input_mode"] = input_mode
        return payload
    if mode == "explain":
        selected_commands = []
        selected_sources = []
        selected_context = ""
    elif mode == "commands":
        selected_commands = commands[:8]
        selected_sources = []
        selected_context = ""
    elif mode == "sources":
        selected_commands = []
        selected_sources = _build_sources(results, limit=5)
        selected_context = context or ""
    else:
        selected_commands = commands[:8]
        selected_sources = _build_sources(results, limit=3)
        selected_context = context or ""

    payload = {
        "status": "ok",
        "mode": mode,
        "format": format_style,
        "query": query,
        "intent": intent,
        "explanation": explanation,
        "commands": selected_commands,
        "sources": selected_sources,
        "context": selected_context,
    }
    if targets:
        payload["targets"] = targets
    if input_mode:
        payload["input_mode"] = input_mode
    return payload


def _resolve_plan_path(raw_value: str) -> Path:
    candidate = Path(raw_value).expanduser()
    if len(candidate.parts) == 1:
        DEFAULT_PLANS_DIR.mkdir(parents=True, exist_ok=True)
        return DEFAULT_PLANS_DIR / candidate.name
    candidate.parent.mkdir(parents=True, exist_ok=True)
    return candidate


def _extract_plan_meta_from_text(raw_text: str) -> tuple[str, str, str]:
    intent = ""
    goal = ""
    query = ""
    tags: list[str] = []
    lines = [ln.strip() for ln in raw_text.splitlines() if ln.strip()]
    for ln in lines:
        lower_ln = ln.lower()
        if not intent and (lower_ln.startswith("intencao:") or lower_ln.startswith("intencao detectada:")):
            intent = ln.split(":", 1)[1].strip()
        elif not goal and (lower_ln.startswith("objetivo:") or lower_ln.startswith("goal:")):
            goal = ln.split(":", 1)[1].strip()
        elif not query and lower_ln.startswith("pergunta:"):
            query = ln.split(":", 1)[1].strip()
        elif not goal and lower_ln.startswith("titulo:"):
            goal = ln.split(":", 1)[1].strip()
        elif not tags and lower_ln.startswith("tags:"):
            raw_tags = ln.split(":", 1)[1].strip()
            tags = [t.strip() for t in raw_tags.split(",") if t.strip()]
    if not goal and lines:
        goal = lines[0][:120]
    return intent, goal, query, tags


def _str_to_bool(raw: str) -> bool:
    return str(raw or "").strip().lower() in {"1", "true", "yes", "y", "on"}


def _rewrite_or_insert_header(raw_text: str, header: str, value: str) -> str:
    lines = raw_text.splitlines()
    low_header = header.lower() + ":"
    replaced = False
    out: list[str] = []
    for ln in lines:
        if ln.strip().lower().startswith(low_header):
            out.append(f"{header}: {value}")
            replaced = True
        else:
            out.append(ln)
    if not replaced:
        insert_at = 0
        while insert_at < len(out) and not out[insert_at].strip():
            insert_at += 1
        out.insert(insert_at, f"{header}: {value}")
    return "\n".join(out).rstrip() + "\n"


def _remove_header(raw_text: str, header: str) -> str:
    lines = raw_text.splitlines()
    low_header = header.lower() + ":"
    out = [ln for ln in lines if not ln.strip().lower().startswith(low_header)]
    return "\n".join(out).rstrip() + ("\n" if out else "")


def _read_plan_metadata(path: Path) -> dict:
    st = path.stat()
    meta = {
        "name": path.name,
        "path": str(path),
        "size": int(st.st_size),
        "mtime": datetime.fromtimestamp(st.st_mtime).isoformat(timespec="seconds"),
        "intent": "",
        "goal": "",
        "query": "",
        "tags": [],
        "deprecated": False,
        "deprecated_at": "",
        "context": {},
        "incident_type": "",
    }
    suffix = path.suffix.lower()
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except Exception:
        return meta

    if suffix == ".json":
        try:
            data = json.loads(raw)
            if isinstance(data, dict):
                meta["intent"] = str(data.get("intent", "") or "").strip()
                meta["query"] = str(data.get("query", "") or "").strip()
                title = str(data.get("title", "") or "").strip()
                goal = str(data.get("goal", "") or "").strip()
                meta["goal"] = goal or title
                raw_tags = data.get("tags", [])
                if isinstance(raw_tags, list):
                    meta["tags"] = [str(t).strip() for t in raw_tags if str(t).strip()]
                meta["deprecated"] = bool(data.get("deprecated", False))
                meta["deprecated_at"] = str(data.get("deprecated_at", "") or "")
                ctx = data.get("context", {})
                if isinstance(ctx, dict):
                    c_out = {}
                    for k in ("cluster", "namespace", "environment"):
                        v = str(ctx.get(k, "") or "").strip()
                        if v:
                            c_out[k] = v
                    meta["context"] = c_out
                it = str(data.get("incident_type", "") or "").strip().lower()
                if it in ALLOWED_INCIDENT_TYPES:
                    meta["incident_type"] = it
                return meta
        except json.JSONDecodeError:
            pass

    intent, goal, query, tags = _extract_plan_meta_from_text(raw)
    meta["intent"] = intent
    meta["goal"] = goal
    meta["query"] = query
    meta["tags"] = tags
    lines = [ln.strip() for ln in raw.splitlines() if ln.strip()]
    for ln in lines:
        low_ln = ln.lower()
        if low_ln.startswith("deprecated:"):
            meta["deprecated"] = _str_to_bool(ln.split(":", 1)[1].strip())
        elif low_ln.startswith("deprecated-at:"):
            meta["deprecated_at"] = ln.split(":", 1)[1].strip()
        elif low_ln.startswith("cluster:"):
            v = ln.split(":", 1)[1].strip()
            if v:
                meta.setdefault("context", {})["cluster"] = v
        elif low_ln.startswith("namespace:"):
            v = ln.split(":", 1)[1].strip()
            if v:
                meta.setdefault("context", {})["namespace"] = v
        elif low_ln.startswith("environment:"):
            v = ln.split(":", 1)[1].strip()
            if v:
                meta.setdefault("context", {})["environment"] = v
        elif low_ln.startswith("incident-type:"):
            it = ln.split(":", 1)[1].strip().lower()
            if it in ALLOWED_INCIDENT_TYPES:
                meta["incident_type"] = it
    return meta


def _plan_matches(meta: dict, intent_filter: str, search_filter: str, tag_filter: str, incident_type_filter: str) -> bool:
    name = str(meta.get("name", "") or "")
    intent = str(meta.get("intent", "") or "")
    goal = str(meta.get("goal", "") or "")
    query = str(meta.get("query", "") or "")
    tags = [str(t).strip().lower() for t in (meta.get("tags", []) or []) if str(t).strip()]
    incident_type = str(meta.get("incident_type", "") or "").strip().lower()
    haystack = " ".join([name, intent, goal, query, ",".join(tags)]).lower()

    if intent_filter:
        needle = intent_filter.lower()
        intent_match = needle in intent.lower() or needle in query.lower() or needle in name.lower()
        if not intent_match:
            return False
    if search_filter and search_filter.lower() not in haystack:
        return False
    if tag_filter:
        needle = tag_filter.lower().strip()
        if needle not in tags:
            return False
    if incident_type_filter:
        if incident_type != incident_type_filter.lower().strip():
            return False
    return True


def _list_plans(intent_filter: str = "", search_filter: str = "", tag_filter: str = "", incident_type_filter: str = "") -> list[dict]:
    DEFAULT_PLANS_DIR.mkdir(parents=True, exist_ok=True)
    entries: list[dict] = []
    for item in sorted(DEFAULT_PLANS_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
        if not item.is_file():
            continue
        if item.suffix.lower() not in {".json", ".txt"}:
            continue
        meta = _read_plan_metadata(item)
        if _plan_matches(
            meta,
            intent_filter=intent_filter,
            search_filter=search_filter,
            tag_filter=tag_filter,
            incident_type_filter=incident_type_filter,
        ):
            entries.append(meta)
    return entries


def _render_list_plans_text(plans: list[dict]) -> None:
    print(f"Plans dir: {DEFAULT_PLANS_DIR}")
    if not plans:
        print("(nenhum plano salvo)")
        return
    for p in plans:
        name = p.get("name", "")
        mtime = p.get("mtime", "")
        size = p.get("size", 0)
        intent = str(p.get("intent", "") or "").strip() or "(sem intent)"
        goal = str(p.get("goal", "") or "").strip() or "(sem goal/titulo)"
        query = str(p.get("query", "") or "").strip()
        tags = p.get("tags", []) or []
        deprecated = bool(p.get("deprecated", False))
        deprecated_at = str(p.get("deprecated_at", "") or "")
        incident_type = str(p.get("incident_type", "") or "").strip()
        if len(goal) > 110:
            goal = goal[:110] + "..."
        dep_suffix = " [DEPRECATED]" if deprecated else ""
        print(f"- {name}{dep_suffix}")
        print(f"  mtime: {mtime} | size: {size}")
        if deprecated_at:
            print(f"  deprecated_at: {deprecated_at}")
        print(f"  intent: {intent}")
        print(f"  goal: {goal}")
        if tags:
            print(f"  tags: {','.join(str(t) for t in tags)}")
        if incident_type:
            print(f"  incident_type: {incident_type}")
        ctx = p.get("context", {}) or {}
        if isinstance(ctx, dict) and ctx:
            parts = []
            for k in ("cluster", "namespace", "environment"):
                v = str(ctx.get(k, "") or "").strip()
                if v:
                    parts.append(f"{k}={v}")
            if parts:
                print(f"  context: {' | '.join(parts)}")
        if query:
            q = query if len(query) <= 110 else query[:110] + "..."
            print(f"  query: {q}")


def _plan_candidates() -> list[Path]:
    DEFAULT_PLANS_DIR.mkdir(parents=True, exist_ok=True)
    candidates: list[Path] = []
    for item in sorted(DEFAULT_PLANS_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
        if item.is_file() and item.suffix.lower() in {".json", ".txt"}:
            candidates.append(item)
    return candidates


def _plan_candidates_from_dir(base_dir: Path) -> list[Path]:
    base_dir.mkdir(parents=True, exist_ok=True)
    candidates: list[Path] = []
    for item in sorted(base_dir.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
        if item.is_file() and item.suffix.lower() in {".json", ".txt"}:
            candidates.append(item)
    return candidates


def _resolve_plan_from_dir(name: str, base_dir: Path) -> tuple[str, Path | None, list[str]]:
    wanted = (name or "").strip()
    if not wanted:
        return "not_found", None, []
    candidates = _plan_candidates_from_dir(base_dir)

    exact = [p for p in candidates if p.name == wanted]
    if len(exact) == 1:
        return "ok", exact[0], []
    if len(exact) > 1:
        return "ambiguous", None, [p.name for p in exact]

    low = wanted.lower()
    partial = [p for p in candidates if low in p.name.lower()]
    if len(partial) == 1:
        return "ok", partial[0], []
    if len(partial) > 1:
        return "ambiguous", None, [p.name for p in partial]
    return "not_found", None, []


def _resolve_plan_anywhere(name: str) -> tuple[str, Path | None, list[str]]:
    wanted = (name or "").strip()
    if not wanted:
        return "not_found", None, []
    candidates = _plan_candidates_from_dir(DEFAULT_PLANS_DIR) + _plan_candidates_from_dir(DEFAULT_ARCHIVE_PLANS_DIR)

    exact = [p for p in candidates if p.name == wanted]
    if len(exact) == 1:
        return "ok", exact[0], []
    if len(exact) > 1:
        return "ambiguous", None, [f"{p.name} ({p.parent})" for p in exact]

    low = wanted.lower()
    partial = [p for p in candidates if low in p.name.lower()]
    if len(partial) == 1:
        return "ok", partial[0], []
    if len(partial) > 1:
        return "ambiguous", None, [f"{p.name} ({p.parent})" for p in partial]
    return "not_found", None, []


def _resolve_show_plan(name: str) -> tuple[str, Path | None, list[str]]:
    wanted = (name or "").strip()
    if not wanted:
        return "not_found", None, []
    candidates = _plan_candidates()

    for p in candidates:
        if p.name == wanted:
            return "ok", p, []

    low = wanted.lower()
    partial = [p for p in candidates if low in p.name.lower()]
    if len(partial) == 1:
        return "ok", partial[0], []
    if len(partial) > 1:
        return "ambiguous", None, [p.name for p in partial]
    return "not_found", None, []


def _list_archived_plans() -> list[dict]:
    entries: list[dict] = []
    for item in _plan_candidates_from_dir(DEFAULT_ARCHIVE_PLANS_DIR):
        entries.append(_read_plan_metadata(item))
    return entries


def _sync_favorite_archive_flag(plan_name: str, archived: bool, new_path: str) -> None:
    state = _load_favorites_state()
    favorites = state.get("favorites", [])
    if not isinstance(favorites, list):
        return
    changed = False
    for item in favorites:
        if not isinstance(item, dict):
            continue
        if str(item.get("name", "") or "") != plan_name:
            continue
        item["path"] = new_path
        if archived:
            item["archived"] = True
        else:
            item.pop("archived", None)
        changed = True
    if changed:
        _save_favorites_state(favorites)


def _archive_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    DEFAULT_ARCHIVE_PLANS_DIR.mkdir(parents=True, exist_ok=True)
    destination = DEFAULT_ARCHIVE_PLANS_DIR / path.name
    if destination.exists():
        return "error", {"status": "error", "error": f"plano ja arquivado com mesmo nome: {destination.name}"}

    path.rename(destination)
    _sync_favorite_archive_flag(destination.name, archived=True, new_path=str(destination))
    return "ok", {"status": "ok", "archived_from": str(path), "archived_to": str(destination), "name": destination.name}


def _restore_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_plan_from_dir(plan_name, DEFAULT_ARCHIVE_PLANS_DIR)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano arquivado nao encontrado: {plan_name}"}

    DEFAULT_PLANS_DIR.mkdir(parents=True, exist_ok=True)
    destination = DEFAULT_PLANS_DIR / path.name
    if destination.exists():
        return "error", {"status": "error", "error": f"ja existe plano ativo com esse nome: {destination.name}"}

    path.rename(destination)
    _sync_favorite_archive_flag(destination.name, archived=False, new_path=str(destination))
    return "ok", {"status": "ok", "restored_from": str(path), "restored_to": str(destination), "name": destination.name}


def _load_show_plan(path: Path) -> dict:
    meta = _read_plan_metadata(path)
    st = path.stat()
    out = {
        "name": path.name,
        "path": str(path),
        "size": int(st.st_size),
        "mtime": datetime.fromtimestamp(st.st_mtime).isoformat(timespec="seconds"),
        "tags": meta.get("tags", []) or [],
        "deprecated": bool(meta.get("deprecated", False)),
        "deprecated_at": str(meta.get("deprecated_at", "") or ""),
        "context": meta.get("context", {}) or {},
        "incident_type": str(meta.get("incident_type", "") or ""),
        "content_type": "text",
        "content": "",
    }
    raw = path.read_text(encoding="utf-8", errors="replace")
    if path.suffix.lower() == ".json":
        try:
            parsed = json.loads(raw)
            out["content_type"] = "json"
            out["content"] = parsed
            return out
        except json.JSONDecodeError:
            out["content_type"] = "text"
    out["content"] = raw
    return out


def _text_for_diff(path: Path) -> tuple[str, str]:
    raw = path.read_text(encoding="utf-8", errors="replace")
    if path.suffix.lower() == ".json":
        try:
            parsed = json.loads(raw)
            pretty = json.dumps(parsed, ensure_ascii=False, indent=2, sort_keys=True)
            return "json", pretty + "\n"
        except json.JSONDecodeError:
            return "text", raw
    return "text", raw


def _diff_plans(left_name: str, right_name: str, save_diff: str = "") -> tuple[str, dict]:
    l_status, l_path, l_candidates = _resolve_plan_anywhere(left_name)
    if l_status == "ambiguous":
        return "error", {"status": "error", "error": "origem ambigua", "candidates": l_candidates}
    if l_status != "ok" or l_path is None:
        return "error", {"status": "error", "error": f"plano origem nao encontrado: {left_name}"}

    r_status, r_path, r_candidates = _resolve_plan_anywhere(right_name)
    if r_status == "ambiguous":
        return "error", {"status": "error", "error": "destino ambiguo", "candidates": r_candidates}
    if r_status != "ok" or r_path is None:
        return "error", {"status": "error", "error": f"plano destino nao encontrado: {right_name}"}

    l_type, l_text = _text_for_diff(l_path)
    r_type, r_text = _text_for_diff(r_path)
    content_type = "json" if l_type == "json" and r_type == "json" else "text"

    diff_lines = list(
        difflib.unified_diff(
            l_text.splitlines(),
            r_text.splitlines(),
            fromfile=str(l_path),
            tofile=str(r_path),
            lineterm="",
        )
    )
    diff_text = "\n".join(diff_lines).rstrip() + ("\n" if diff_lines else "")
    added = sum(1 for ln in diff_lines if ln.startswith("+") and not ln.startswith("+++"))
    removed = sum(1 for ln in diff_lines if ln.startswith("-") and not ln.startswith("---"))
    changed = min(added, removed)

    payload = {
        "status": "ok",
        "left": str(l_path),
        "right": str(r_path),
        "content_type": content_type,
        "summary": {"added": added, "removed": removed, "changed": changed},
        "diff": diff_text,
    }
    if save_diff.strip():
        out = Path(save_diff.strip()).expanduser()
        if len(out.parts) == 1:
            DEFAULT_DIFFS_DIR.mkdir(parents=True, exist_ok=True)
            out = DEFAULT_DIFFS_DIR / out.name
        else:
            out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(diff_text, encoding="utf-8")
        payload["saved_diff"] = str(out)
    return "ok", payload


def _render_diff_text(payload: dict) -> None:
    print(f"Origem: {payload.get('left', '')}")
    print(f"Destino: {payload.get('right', '')}")
    print(f"Tipo: {payload.get('content_type', 'text')}")
    summary = payload.get("summary", {}) or {}
    print(f"Resumo: +{summary.get('added', 0)} -{summary.get('removed', 0)} ~{summary.get('changed', 0)}")
    if payload.get("saved_diff"):
        print(f"Diff salvo em: {payload.get('saved_diff', '')}")
    print("\nDiff:")
    print(str(payload.get("diff", "") or "(sem diferencas)"))


def _resolve_merge_output_path(raw_value: str) -> Path:
    out = Path(raw_value).expanduser()
    if len(out.parts) == 1:
        DEFAULT_MERGE_DIR.mkdir(parents=True, exist_ok=True)
        return DEFAULT_MERGE_DIR / out.name
    out.parent.mkdir(parents=True, exist_ok=True)
    return out


def _collect_commands_for_merge(plan_data: dict, raw_text: str) -> list[str]:
    out: list[str] = []
    if isinstance(plan_data, dict):
        for key in ("commands", "prechecks", "validation"):
            val = plan_data.get(key)
            if isinstance(val, list):
                for c in val:
                    s = str(c).strip()
                    if s:
                        out.append(s)
        steps = plan_data.get("plan_steps")
        if isinstance(steps, list):
            for step in steps:
                if not isinstance(step, dict):
                    continue
                cmds = step.get("commands")
                if isinstance(cmds, list):
                    for c in cmds:
                        s = str(c).strip()
                        if s:
                            out.append(s)
    out.extend(_extract_commands(raw_text))
    dedup: list[str] = []
    seen = set()
    for c in out:
        key = c.lower()
        if key in seen:
            continue
        seen.add(key)
        dedup.append(c)
    return dedup


def _merge_plans(left_name: str, right_name: str, save_merge: str = "") -> tuple[str, dict]:
    l_status, l_path, l_candidates = _resolve_show_plan(left_name)
    if l_status == "ambiguous":
        return "error", {"status": "error", "error": "origem ambigua", "candidates": l_candidates}
    if l_status != "ok" or l_path is None:
        return "error", {"status": "error", "error": f"plano origem nao encontrado: {left_name}"}

    r_status, r_path, r_candidates = _resolve_show_plan(right_name)
    if r_status == "ambiguous":
        return "error", {"status": "error", "error": "destino ambiguo", "candidates": r_candidates}
    if r_status != "ok" or r_path is None:
        return "error", {"status": "error", "error": f"plano destino nao encontrado: {right_name}"}

    l_meta = _read_plan_metadata(l_path)
    r_meta = _read_plan_metadata(r_path)
    l_raw = l_path.read_text(encoding="utf-8", errors="replace")
    r_raw = r_path.read_text(encoding="utf-8", errors="replace")

    try:
        l_json = json.loads(l_raw) if l_path.suffix.lower() == ".json" else None
    except json.JSONDecodeError:
        l_json = None
    try:
        r_json = json.loads(r_raw) if r_path.suffix.lower() == ".json" else None
    except json.JSONDecodeError:
        r_json = None

    conflicts: list[str] = []
    if isinstance(l_json, dict) and isinstance(r_json, dict):
        merged: dict = {}
        merged["intent"] = l_meta.get("intent") or r_meta.get("intent") or ""
        if l_meta.get("intent") and r_meta.get("intent") and l_meta.get("intent") != r_meta.get("intent"):
            conflicts.append("intent conflitante entre origem e destino")
        merged["goal"] = l_meta.get("goal") or r_meta.get("goal") or ""
        if l_meta.get("goal") and r_meta.get("goal") and l_meta.get("goal") != r_meta.get("goal"):
            conflicts.append("goal conflitante entre origem e destino")

        tags = []
        for t in (l_meta.get("tags", []) or []) + (r_meta.get("tags", []) or []):
            ts = str(t).strip()
            if ts and ts not in tags:
                tags.append(ts)
        merged["tags"] = tags

        commands = _collect_commands_for_merge(l_json, l_raw) + _collect_commands_for_merge(r_json, r_raw)
        cmd_dedup: list[str] = []
        seen = set()
        for c in commands:
            key = c.lower()
            if key in seen:
                continue
            seen.add(key)
            cmd_dedup.append(c)
        merged["commands"] = cmd_dedup

        l_ctx = l_meta.get("context", {}) or {}
        r_ctx = r_meta.get("context", {}) or {}
        merged_ctx = {}
        for k in ("cluster", "namespace", "environment"):
            lv = str(l_ctx.get(k, "") or "").strip()
            rv = str(r_ctx.get(k, "") or "").strip()
            if lv and rv and lv != rv:
                conflicts.append(f"contexto conflitante em {k}: '{lv}' vs '{rv}'")
            merged_ctx[k] = lv or rv
        merged["context"] = {k: v for k, v in merged_ctx.items() if v}
        merge_preview = merged
    else:
        l_cmd = _collect_commands_for_merge(l_json if isinstance(l_json, dict) else {}, l_raw)
        r_cmd = _collect_commands_for_merge(r_json if isinstance(r_json, dict) else {}, r_raw)
        merged_cmd = []
        seen = set()
        for c in l_cmd + r_cmd:
            key = c.lower()
            if key in seen:
                continue
            seen.add(key)
            merged_cmd.append(c)
        merge_preview = {
            "source_a": {"name": l_path.name, "intent": l_meta.get("intent", ""), "goal": l_meta.get("goal", "")},
            "source_b": {"name": r_path.name, "intent": r_meta.get("intent", ""), "goal": r_meta.get("goal", "")},
            "combined_commands": merged_cmd,
            "notes": "merge textual assistido por blocos",
        }
        if l_meta.get("intent") and r_meta.get("intent") and l_meta.get("intent") != r_meta.get("intent"):
            conflicts.append("intent conflitante entre os dois planos")

    payload = {
        "status": "ok",
        "left": str(l_path),
        "right": str(r_path),
        "merge_preview": merge_preview,
        "conflicts": conflicts,
    }
    if save_merge.strip():
        out = _resolve_merge_output_path(save_merge.strip())
        if out.exists():
            return "error", {"status": "error", "error": f"destino de merge ja existe: {out}"}
        if out.suffix.lower() == ".json":
            out.write_text(json.dumps(merge_preview, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
        else:
            out.write_text(
                f"Merge Preview\n\nLeft: {l_path}\nRight: {r_path}\n\n{json.dumps(merge_preview, ensure_ascii=False, indent=2)}\n\nConflicts:\n- "
                + ("\n- ".join(conflicts) if conflicts else "(sem conflitos)\n"),
                encoding="utf-8",
            )
        payload["saved_merge"] = str(out)
    return "ok", payload


def _render_merge_text(payload: dict) -> None:
    print(f"Origem: {payload.get('left', '')}")
    print(f"Destino: {payload.get('right', '')}")
    conflicts = payload.get("conflicts", []) or []
    print(f"Itens combinados: merge_preview pronto")
    print(f"Conflitos: {len(conflicts)}")
    if payload.get("saved_merge"):
        print(f"Merge salvo em: {payload.get('saved_merge', '')}")
    print("\nPreview:")
    print(json.dumps(payload.get("merge_preview", {}), ensure_ascii=False, indent=2))
    if conflicts:
        print("\nConflicts:")
        for c in conflicts:
            print(f"- {c}")


def _find_duplicates_payload() -> dict:
    plans = _list_plans()
    rows: list[dict] = []
    for i in range(len(plans)):
        for j in range(i + 1, len(plans)):
            a = plans[i]
            b = plans[j]
            reasons = []
            score = 0.0
            if str(a.get("intent", "")).strip() and str(a.get("intent", "")).strip() == str(b.get("intent", "")).strip():
                score += 0.30
                reasons.append("intent match")
            a_tags = set(str(t).lower() for t in (a.get("tags", []) or []))
            b_tags = set(str(t).lower() for t in (b.get("tags", []) or []))
            if a_tags and b_tags:
                inter = len(a_tags.intersection(b_tags))
                union = len(a_tags.union(b_tags))
                if union:
                    tag_sim = inter / union
                    score += 0.20 * tag_sim
                    if tag_sim > 0:
                        reasons.append(f"tags overlap={tag_sim:.2f}")
            a_goal = set(_tokenize_text(str(a.get("goal", "") or "")))
            b_goal = set(_tokenize_text(str(b.get("goal", "") or "")))
            if a_goal and b_goal:
                inter = len(a_goal.intersection(b_goal))
                union = len(a_goal.union(b_goal))
                if union:
                    goal_sim = inter / union
                    score += 0.20 * goal_sim
                    if goal_sim > 0:
                        reasons.append(f"goal overlap={goal_sim:.2f}")
            a_name = set(_tokenize_text(str(a.get("name", "") or "")))
            b_name = set(_tokenize_text(str(b.get("name", "") or "")))
            if a_name and b_name:
                inter = len(a_name.intersection(b_name))
                union = len(a_name.union(b_name))
                if union:
                    name_sim = inter / union
                    score += 0.10 * name_sim
                    if name_sim > 0:
                        reasons.append(f"name overlap={name_sim:.2f}")
            if str(a.get("query", "") or "").strip() and str(a.get("query", "") or "").strip() == str(b.get("query", "") or "").strip():
                score += 0.20
                reasons.append("query equal")

            a_cmd = _extract_commands_from_text_content(Path(str(a.get("path", ""))).read_text(encoding="utf-8", errors="replace"))
            b_cmd = _extract_commands_from_text_content(Path(str(b.get("path", ""))).read_text(encoding="utf-8", errors="replace"))
            if a_cmd and b_cmd:
                ai = set(c.lower() for c in a_cmd)
                bi = set(c.lower() for c in b_cmd)
                inter = len(ai.intersection(bi))
                union = len(ai.union(bi))
                if union:
                    cmd_sim = inter / union
                    score += 0.20 * cmd_sim
                    if cmd_sim > 0:
                        reasons.append(f"commands overlap={cmd_sim:.2f}")

            if score >= 0.60:
                rows.append(
                    {
                        "left": a.get("name", ""),
                        "right": b.get("name", ""),
                        "score": round(score, 3),
                        "reasons": reasons,
                        "merge_candidate": True,
                    }
                )
    rows.sort(key=lambda x: float(x.get("score", 0.0)), reverse=True)
    payload = {"status": "ok", "duplicates": rows}

    DEFAULT_CATALOG_DIR.mkdir(parents=True, exist_ok=True)
    dup_json = DEFAULT_CATALOG_DIR / "duplicates.json"
    dup_md = DEFAULT_CATALOG_DIR / "duplicates.md"
    dup_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    lines = ["# Potential Duplicates", ""]
    if not rows:
        lines.append("(nenhum par suspeito)")
    for r in rows:
        lines.append(f"- {r.get('left', '')} <-> {r.get('right', '')} | score={r.get('score', 0)}")
        for reason in r.get("reasons", []) or []:
            lines.append(f"  - {reason}")
        lines.append("  - candidato_merge: yes")
    dup_md.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    payload["duplicates_json"] = str(dup_json)
    payload["duplicates_md"] = str(dup_md)
    return payload


def _render_show_plan_text(plan: dict) -> None:
    print(f"Plan: {plan.get('name', '')}")
    print(f"Path: {plan.get('path', '')}")
    print(f"Size: {plan.get('size', 0)}")
    print(f"Mtime: {plan.get('mtime', '')}")
    tags = plan.get("tags", []) or []
    if tags:
        print(f"Tags: {','.join(str(t) for t in tags)}")
    if plan.get("deprecated"):
        print(f"Deprecated: true")
        print(f"Deprecated-At: {plan.get('deprecated_at', '')}")
    if str(plan.get("incident_type", "") or "").strip():
        print(f"Incident-Type: {plan.get('incident_type', '')}")
    ctx = plan.get("context", {}) or {}
    if isinstance(ctx, dict) and ctx:
        print("Context:")
        for key in ("cluster", "namespace", "environment"):
            val = str(ctx.get(key, "") or "").strip()
            if val:
                print(f"- {key}: {val}")
    print(f"Content-Type: {plan.get('content_type', 'text')}")
    print("\nContent:")
    if plan.get("content_type") == "json":
        print(json.dumps(plan.get("content", {}), ensure_ascii=False, indent=2))
    else:
        content = str(plan.get("content", "") or "")
        print(content.rstrip())


def _history_backup_path_for(destination: Path) -> Path:
    DEFAULT_HISTORY_PLANS_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%dT%H%M%SZ")
    return DEFAULT_HISTORY_PLANS_DIR / f"{destination.name}.{stamp}.bak"


def _version_existing_destination(destination: Path) -> dict:
    backup_path = _history_backup_path_for(destination)
    destination.rename(backup_path)
    size = int(backup_path.stat().st_size)
    return {"path": str(backup_path), "size": size}


def _list_history_entries() -> list[dict]:
    DEFAULT_HISTORY_PLANS_DIR.mkdir(parents=True, exist_ok=True)
    rows: list[dict] = []
    for item in sorted(DEFAULT_HISTORY_PLANS_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
        if not item.is_file():
            continue
        st = item.stat()
        rows.append(
            {
                "name": item.name,
                "path": str(item),
                "mtime": datetime.fromtimestamp(st.st_mtime).isoformat(timespec="seconds"),
                "size": int(st.st_size),
            }
        )
    return rows


def _show_history(plan_name: str) -> tuple[str, dict]:
    wanted = (plan_name or "").strip()
    if not wanted:
        return "error", {"status": "error", "error": "informe o nome do plano em --show-history"}

    entries: list[dict] = []
    active = DEFAULT_PLANS_DIR / wanted
    if active.exists() and active.is_file():
        st = active.stat()
        entries.append(
            {
                "name": active.name,
                "path": str(active),
                "mtime": datetime.fromtimestamp(st.st_mtime).isoformat(timespec="seconds"),
                "size": int(st.st_size),
                "kind": "current",
            }
        )

    archived = DEFAULT_ARCHIVE_PLANS_DIR / wanted
    if archived.exists() and archived.is_file():
        st = archived.stat()
        entries.append(
            {
                "name": archived.name,
                "path": str(archived),
                "mtime": datetime.fromtimestamp(st.st_mtime).isoformat(timespec="seconds"),
                "size": int(st.st_size),
                "kind": "archived",
            }
        )

    for item in _list_history_entries():
        name = str(item.get("name", "") or "")
        if name.startswith(wanted + ".") and name.endswith(".bak"):
            entries.append({**item, "kind": "history"})

    entries.sort(key=lambda x: str(x.get("mtime", "")), reverse=True)
    if not entries:
        return "error", {"status": "error", "error": f"nenhum historico encontrado para: {wanted}"}
    return "ok", {"status": "ok", "plan": wanted, "history": entries}


def _render_history_text(payload: dict) -> None:
    print(f"Plano: {payload.get('plan', '')}")
    rows = payload.get("history", []) or []
    if not rows:
        print("(sem historico)")
        return
    for row in rows:
        print(f"- {row.get('name', '')} [{row.get('kind', 'history')}]")
        print(f"  path: {row.get('path', '')}")
        print(f"  mtime: {row.get('mtime', '')} | size: {row.get('size', 0)}")


def _copy_plan(source_name: str, destination_raw: str, versioned_save: bool = False) -> tuple[str, dict]:
    status, source_path, candidates = _resolve_show_plan(source_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or source_path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {source_name}"}

    destination = _resolve_plan_path(destination_raw)
    if source_path.resolve() == destination.resolve():
        return "error", {"status": "error", "error": "origem e destino sao o mesmo arquivo"}
    versioned = None
    if destination.exists() and versioned_save:
        versioned = _version_existing_destination(destination)
    elif destination.exists():
        return "error", {"status": "error", "error": f"destino ja existe: {destination}"}

    source_suffix = source_path.suffix.lower()
    content_type = "json" if source_suffix == ".json" else "text"
    shutil.copy2(source_path, destination)
    copied_size = int(destination.stat().st_size)
    payload = {
        "status": "ok",
        "copied_from": str(source_path),
        "copied_to": str(destination),
        "content_type": content_type,
        "size": copied_size,
        "tags": _read_plan_metadata(source_path).get("tags", []) or [],
    }
    if versioned:
        payload["versioned_backup"] = versioned
    return "ok", payload


def _rename_plan(source_name: str, destination_raw: str, versioned_save: bool = False) -> tuple[str, dict]:
    status, source_path, candidates = _resolve_show_plan(source_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or source_path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {source_name}"}

    destination = _resolve_plan_path(destination_raw)
    if source_path.resolve() == destination.resolve():
        return "error", {"status": "error", "error": "origem e destino sao o mesmo arquivo"}
    versioned = None
    if destination.exists() and versioned_save:
        versioned = _version_existing_destination(destination)
    elif destination.exists():
        return "error", {"status": "error", "error": f"destino ja existe: {destination}"}

    source_suffix = source_path.suffix.lower()
    content_type = "json" if source_suffix == ".json" else "text"
    source_path.rename(destination)
    size = int(destination.stat().st_size)
    payload = {
        "status": "ok",
        "renamed_from": str(source_path),
        "renamed_to": str(destination),
        "size": size,
        "content_type": content_type,
    }
    if versioned:
        payload["versioned_backup"] = versioned
    return "ok", payload


def _build_catalog() -> dict:
    DEFAULT_CATALOG_DIR.mkdir(parents=True, exist_ok=True)
    plans = _list_plans()
    plans_sorted = sorted(plans, key=lambda p: str(p.get("name", "")))
    catalog_plans = []
    for p in plans_sorted:
        catalog_plans.append(
            {
                "name": p.get("name", ""),
                "intent": p.get("intent", ""),
                "goal": p.get("goal", ""),
                "tags": p.get("tags", []) or [],
                "path": p.get("path", ""),
                "size": p.get("size", 0),
            }
        )

    catalog_json = {
        "generated_at": datetime.now().isoformat(timespec="seconds"),
        "plans": catalog_plans,
    }
    catalog_json_path = DEFAULT_CATALOG_DIR / "catalog.json"
    catalog_md_path = DEFAULT_CATALOG_DIR / "catalog.md"
    catalog_json_path.write_text(json.dumps(catalog_json, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

    lines = ["# Livecopilot Runbook Catalog", ""]
    for item in catalog_plans:
        lines.append(f"## {item.get('name', '')}")
        lines.append("")
        lines.append(f"nome: {item.get('name', '')}")
        lines.append(f"intent: {item.get('intent', '')}")
        lines.append(f"goal: {item.get('goal', '')}")
        tags = item.get("tags", []) or []
        lines.append(f"tags: {','.join(str(t) for t in tags) if tags else '(sem tags)'}")
        lines.append(f"arquivo: {item.get('path', '')}")
        lines.append("")
    catalog_md_path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")

    return {
        "status": "ok",
        "catalog_dir": str(DEFAULT_CATALOG_DIR),
        "catalog_json": str(catalog_json_path),
        "catalog_md": str(catalog_md_path),
        "plans_count": len(catalog_plans),
    }


def _extract_export_sections(path: Path, plan_data: dict) -> tuple[str, str, list[str], list[str], list[str], list[str], list[str]]:
    intent = str(plan_data.get("intent", "") or "")
    goal = str(plan_data.get("goal", "") or "")
    tags = [str(t) for t in (plan_data.get("tags", []) or [])]
    query = str(plan_data.get("query", "") or "")
    commands = _extract_commands_from_text_content(path.read_text(encoding="utf-8", errors="replace"))
    validation: list[str] = []
    prechecks: list[str] = []
    if path.suffix.lower() == ".json":
        try:
            obj = json.loads(path.read_text(encoding="utf-8", errors="replace"))
            if isinstance(obj, dict):
                if not intent:
                    intent = str(obj.get("intent", "") or "")
                if not goal:
                    goal = str(obj.get("goal", "") or str(obj.get("title", "") or ""))
                if not query:
                    query = str(obj.get("query", "") or "")
                if not tags and isinstance(obj.get("tags"), list):
                    tags = [str(t) for t in obj.get("tags", []) if str(t).strip()]
                if isinstance(obj.get("validation"), list):
                    validation = [str(c).strip() for c in obj.get("validation", []) if str(c).strip()]
                if isinstance(obj.get("prechecks"), list):
                    prechecks = [str(c).strip() for c in obj.get("prechecks", []) if str(c).strip()]
        except json.JSONDecodeError:
            pass
    return intent, goal, tags, commands, validation, prechecks, ([query] if query else [])


def _export_plan_to_markdown(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    meta = _read_plan_metadata(path)
    intent, goal, tags, commands, validation, prechecks, queries = _extract_export_sections(path, meta)
    if not commands:
        result_status, payload = _extract_commands_from_saved_plan(path.name)
        if result_status == "ok":
            commands = [str(c) for c in payload.get("commands", [])]

    DEFAULT_DOCS_DIR.mkdir(parents=True, exist_ok=True)
    output_path = DEFAULT_DOCS_DIR / f"{path.stem}.md"
    lines = [
        "# Runbook",
        "",
        path.name,
        "",
        "## Intent",
        "",
        intent or "(sem intent)",
        "",
        "## Goal",
        "",
        goal or "(sem goal)",
        "",
        "## Tags",
        "",
        ",".join(tags) if tags else "(sem tags)",
        "",
    ]
    if queries:
        lines.extend(["## Query", "", queries[0], ""])
    if prechecks:
        lines.extend(["## Prechecks", ""])
        for c in prechecks:
            lines.append(f"- {c}")
        lines.append("")
    lines.extend(["## Commands", ""])
    if commands:
        for c in commands:
            lines.append(f"- {c}")
    else:
        lines.append("- (sem comandos identificados)")
    lines.append("")
    lines.extend(["## Validation", ""])
    if validation:
        for c in validation:
            lines.append(f"- {c}")
    else:
        lines.append("- (sem validacao explicita)")
    lines.append("")
    output_path.write_text("\n".join(lines), encoding="utf-8")

    return "ok", {
        "status": "ok",
        "source_plan": str(path),
        "exported_to": str(output_path),
        "commands_count": len(commands),
    }


def _parse_tags(raw: str) -> list[str]:
    tags: list[str] = []
    seen = set()
    for chunk in (raw or "").split(","):
        tag = chunk.strip().lower()
        if not tag or tag in seen:
            continue
        seen.add(tag)
        tags.append(tag)
    return tags


def _inject_tags_into_saved_plan(content: str, tags: list[str]) -> str:
    if not tags:
        return content
    stripped = content.strip()
    if not stripped:
        return content
    try:
        obj = json.loads(content)
        if isinstance(obj, dict):
            existing = obj.get("tags", [])
            merged: list[str] = []
            seen = set()
            if isinstance(existing, list):
                for item in existing:
                    t = str(item).strip().lower()
                    if t and t not in seen:
                        seen.add(t)
                        merged.append(t)
            for tag in tags:
                if tag not in seen:
                    seen.add(tag)
                    merged.append(tag)
            obj["tags"] = merged
            return json.dumps(obj, ensure_ascii=False)
    except json.JSONDecodeError:
        pass

    header = f"Tags: {','.join(tags)}\n"
    if stripped.lower().startswith("tags:"):
        lines = content.splitlines()
        lines[0] = header.rstrip("\n")
        return "\n".join(lines) + ("\n" if content.endswith("\n") else "")
    return header + content


def _append_cmd_unique(out: list[str], seen: set[str], raw: str) -> None:
    cmd = re.sub(r"\s+", " ", str(raw).strip()).rstrip(".;")
    if cmd.lower().startswith("k "):
        cmd = "kubectl " + cmd[2:].strip()
    key = cmd.lower()
    if not cmd or not key.startswith("kubectl "):
        return
    if key in seen:
        return
    seen.add(key)
    out.append(cmd)


def _extract_commands_from_json_value(value: object, out: list[str], seen: set[str]) -> None:
    if isinstance(value, dict):
        for k, v in value.items():
            lower_k = str(k).lower()
            if lower_k == "commands" and isinstance(v, list):
                for item in v:
                    if isinstance(item, str):
                        _append_cmd_unique(out, seen, item)
            elif lower_k == "runbook" and isinstance(v, dict):
                _extract_commands_from_json_value(v, out, seen)
            else:
                _extract_commands_from_json_value(v, out, seen)
        return
    if isinstance(value, list):
        for item in value:
            _extract_commands_from_json_value(item, out, seen)
        return
    if isinstance(value, str):
        _append_cmd_unique(out, seen, value)


def _extract_commands_from_text_content(raw: str) -> list[str]:
    out: list[str] = []
    seen: set[str] = set()
    for line in raw.splitlines():
        s = line.strip()
        if not s:
            continue
        s = re.sub(r"^[\-\*\d\.\)\s]+", "", s).strip()
        if s.lower().startswith("kubectl ") or s.lower().startswith("k "):
            _append_cmd_unique(out, seen, s)

    # Fallback para comandos em backticks.
    for cmd in _extract_commands(raw):
        _append_cmd_unique(out, seen, cmd)
    return out


def _extract_commands_from_saved_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    commands: list[str] = []
    seen: set[str] = set()
    raw = path.read_text(encoding="utf-8", errors="replace")
    if path.suffix.lower() == ".json":
        try:
            data = json.loads(raw)
            _extract_commands_from_json_value(data, commands, seen)
        except json.JSONDecodeError:
            commands = _extract_commands_from_text_content(raw)
    else:
        commands = _extract_commands_from_text_content(raw)

    if not commands:
        return "error", {"status": "error", "error": f"plano sem comandos identificaveis: {path.name}"}

    return "ok", {"status": "ok", "plan_name": path.name, "commands": commands}


def _load_json_file(path: Path, default_obj: dict) -> dict:
    if not path.exists():
        return dict(default_obj)
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
        data = json.loads(raw)
        if isinstance(data, dict):
            return data
    except Exception:
        pass
    return dict(default_obj)


def _write_json_file(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def _load_favorites_state() -> dict:
    data = _load_json_file(FAVORITES_PATH, {"updated_at": "", "favorites": []})
    favorites = data.get("favorites", [])
    if not isinstance(favorites, list):
        favorites = []
    return {"updated_at": str(data.get("updated_at", "") or ""), "favorites": favorites}


def _save_favorites_state(favorites: list[dict]) -> dict:
    payload = {"updated_at": datetime.now().isoformat(timespec="seconds"), "favorites": favorites}
    _write_json_file(FAVORITES_PATH, payload)
    return payload


def _favorite_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    state = _load_favorites_state()
    favorites = state.get("favorites", [])
    if not isinstance(favorites, list):
        favorites = []

    for item in favorites:
        if isinstance(item, dict) and str(item.get("name", "")) == path.name:
            state = _save_favorites_state(favorites)
            return "ok", {"status": "ok", "favorite": item, "favorites_count": len(state.get("favorites", []))}

    entry = {"name": path.name, "path": str(path), "favorited_at": datetime.now().isoformat(timespec="seconds")}
    favorites.append(entry)
    state = _save_favorites_state(favorites)
    return "ok", {"status": "ok", "favorite": entry, "favorites_count": len(state.get("favorites", []))}


def _unfavorite_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    state = _load_favorites_state()
    favorites = state.get("favorites", [])
    if not isinstance(favorites, list):
        favorites = []

    remaining = [f for f in favorites if not (isinstance(f, dict) and str(f.get("name", "")) == path.name)]
    if len(remaining) == len(favorites):
        return "error", {"status": "error", "error": f"plano nao esta favoritado: {path.name}"}

    saved = _save_favorites_state(remaining)
    return "ok", {"status": "ok", "removed": path.name, "favorites_count": len(saved.get("favorites", []))}


def _list_favorites() -> dict:
    state = _load_favorites_state()
    favorites = state.get("favorites", [])
    if not isinstance(favorites, list):
        favorites = []
    return {"status": "ok", "updated_at": state.get("updated_at", ""), "favorites": favorites}


def _render_favorites_text(payload: dict) -> None:
    favorites = payload.get("favorites", []) or []
    if not favorites:
        print("(nenhum favorito)")
        return
    for item in favorites:
        if not isinstance(item, dict):
            continue
        print(f"- {item.get('name', '')}")
        print(f"  path: {item.get('path', '')}")
        print(f"  favorited_at: {item.get('favorited_at', '')}")


def _load_usage_state() -> dict:
    data = _load_json_file(USAGE_PATH, {"updated_at": "", "plans": {}})
    plans = data.get("plans", {})
    if not isinstance(plans, dict):
        plans = {}
    return {"updated_at": str(data.get("updated_at", "") or ""), "plans": plans}


def _save_usage_state(plans: dict) -> dict:
    payload = {"updated_at": datetime.now().isoformat(timespec="seconds"), "plans": plans}
    _write_json_file(USAGE_PATH, payload)
    return payload


def _record_plan_usage(plan_name: str, plan_path: str, event: str) -> None:
    state = _load_usage_state()
    plans = state.get("plans", {})
    if not isinstance(plans, dict):
        plans = {}
    now = datetime.now().isoformat(timespec="seconds")
    cur = plans.get(plan_name, {})
    if not isinstance(cur, dict):
        cur = {}
    cur.setdefault("path", plan_path)
    cur.setdefault("open_count", 0)
    cur.setdefault("suggest_count", 0)
    cur.setdefault("selected_count", 0)
    cur.setdefault("last_opened_at", "")
    cur.setdefault("last_suggested_at", "")
    cur.setdefault("last_selected_at", "")

    if event == "open":
        cur["open_count"] = int(cur.get("open_count", 0)) + 1
        cur["last_opened_at"] = now
    elif event == "suggest":
        cur["suggest_count"] = int(cur.get("suggest_count", 0)) + 1
        cur["last_suggested_at"] = now
    elif event == "selected":
        cur["selected_count"] = int(cur.get("selected_count", 0)) + 1
        cur["last_selected_at"] = now

    plans[plan_name] = cur
    _save_usage_state(plans)


def _load_pins_state() -> dict:
    data = _load_json_file(PINS_PATH, {"updated_at": "", "pins": []})
    pins = data.get("pins", [])
    if not isinstance(pins, list):
        pins = []
    return {"updated_at": str(data.get("updated_at", "") or ""), "pins": pins}


def _save_pins_state(pins: list[dict]) -> dict:
    PINS_PATH.parent.mkdir(parents=True, exist_ok=True)
    payload = {"updated_at": datetime.now().isoformat(timespec="seconds"), "pins": pins}
    _write_json_file(PINS_PATH, payload)
    return payload


def _list_pins_payload() -> dict:
    state = _load_pins_state()
    pins = state.get("pins", [])
    if not isinstance(pins, list):
        pins = []
    return {"status": "ok", "pins": pins}


def _pin_plan_for_intent(plan_name: str, intent_name: str) -> tuple[str, dict]:
    if not intent_name.strip():
        return "error", {"status": "error", "error": "informe --for-intent para fixar pin"}
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    state = _load_pins_state()
    pins = state.get("pins", [])
    if not isinstance(pins, list):
        pins = []
    clean_intent = intent_name.strip()
    now = datetime.now().isoformat(timespec="seconds")
    new_entry = {
        "intent": clean_intent,
        "plan_name": path.name,
        "path": str(path),
        "pinned_at": now,
    }
    replaced = False
    kept = []
    for item in pins:
        if isinstance(item, dict) and str(item.get("intent", "") or "") == clean_intent:
            replaced = True
            continue
        kept.append(item)
    kept.append(new_entry)
    _save_pins_state(kept)
    return "ok", {"status": "ok", "pin": new_entry, "replaced": replaced}


def _unpin_plan_for_intent(intent_name: str) -> tuple[str, dict]:
    if not intent_name.strip():
        return "error", {"status": "error", "error": "informe --for-intent para remover pin"}
    state = _load_pins_state()
    pins = state.get("pins", [])
    if not isinstance(pins, list):
        pins = []
    clean_intent = intent_name.strip()
    kept = []
    removed = None
    for item in pins:
        if isinstance(item, dict) and str(item.get("intent", "") or "") == clean_intent and removed is None:
            removed = item
            continue
        kept.append(item)
    if removed is None:
        return "error", {"status": "error", "error": f"pin nao encontrado para intent: {clean_intent}"}
    _save_pins_state(kept)
    return "ok", {"status": "ok", "removed": removed}


def _pinned_plan_for_intent(intent_name: str) -> dict | None:
    state = _load_pins_state()
    for item in state.get("pins", []) or []:
        if not isinstance(item, dict):
            continue
        if str(item.get("intent", "") or "") == intent_name:
            return item
    return None


def _show_usage(target: str | None) -> tuple[str, dict]:
    state = _load_usage_state()
    plans = state.get("plans", {})
    if not isinstance(plans, dict):
        plans = {}

    if not target or target == "__ALL__":
        rows = []
        for name, data in plans.items():
            if not isinstance(data, dict):
                continue
            total = int(data.get("open_count", 0)) + int(data.get("suggest_count", 0)) + int(data.get("selected_count", 0))
            rows.append(
                {
                    "name": name,
                    "path": data.get("path", ""),
                    "open_count": int(data.get("open_count", 0)),
                    "suggest_count": int(data.get("suggest_count", 0)),
                    "selected_count": int(data.get("selected_count", 0)),
                    "last_opened_at": data.get("last_opened_at", ""),
                    "last_suggested_at": data.get("last_suggested_at", ""),
                    "last_selected_at": data.get("last_selected_at", ""),
                    "total": total,
                }
            )
        rows.sort(key=lambda x: (int(x.get("total", 0)), str(x.get("name", ""))), reverse=True)
        return "ok", {"status": "ok", "usage": {"updated_at": state.get("updated_at", ""), "plans": rows}}

    status, path, candidates = _resolve_show_plan(target)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {target}"}
    row = plans.get(path.name)
    if not isinstance(row, dict):
        row = {
            "path": str(path),
            "open_count": 0,
            "suggest_count": 0,
            "selected_count": 0,
            "last_opened_at": "",
            "last_suggested_at": "",
            "last_selected_at": "",
        }
    return "ok", {"status": "ok", "usage": {"name": path.name, **row}}


def _render_usage_text(payload: dict) -> None:
    usage = payload.get("usage", {})
    if not isinstance(usage, dict):
        print("(sem uso)")
        return
    if "plans" in usage:
        plans = usage.get("plans", []) or []
        if not plans:
            print("(sem historico de uso)")
            return
        for item in plans[:10]:
            print(
                f"- {item.get('name', '')} | open={item.get('open_count', 0)} | suggest={item.get('suggest_count', 0)} | selected={item.get('selected_count', 0)}"
            )
        return
    print(f"name: {usage.get('name', '')}")
    print(f"path: {usage.get('path', '')}")
    print(f"open_count: {usage.get('open_count', 0)}")
    print(f"suggest_count: {usage.get('suggest_count', 0)}")
    print(f"selected_count: {usage.get('selected_count', 0)}")
    print(f"last_opened_at: {usage.get('last_opened_at', '')}")
    print(f"last_suggested_at: {usage.get('last_suggested_at', '')}")
    print(f"last_selected_at: {usage.get('last_selected_at', '')}")


def _favorite_names_set() -> set[str]:
    state = _load_favorites_state()
    out: set[str] = set()
    for item in state.get("favorites", []) or []:
        if isinstance(item, dict):
            name = str(item.get("name", "") or "").strip()
            if name:
                out.add(name)
    return out


def _usage_for_plan_name(name: str) -> dict:
    state = _load_usage_state()
    plans = state.get("plans", {})
    if not isinstance(plans, dict):
        return {}
    row = plans.get(name, {})
    return row if isinstance(row, dict) else {}


def _recency_boost(iso_ts: str) -> int:
    if not iso_ts:
        return 0
    try:
        dt = datetime.fromisoformat(iso_ts)
    except Exception:
        return 0
    age_days = (datetime.now() - dt).total_seconds() / 86400.0
    if age_days <= 1:
        return 3
    if age_days <= 7:
        return 2
    if age_days <= 30:
        return 1
    return 0


def _build_top_plans_usage() -> dict:
    favorites = _favorite_names_set()
    plans_meta = _list_plans()
    out: list[dict] = []
    for meta in plans_meta:
        name = str(meta.get("name", "") or "")
        usage = _usage_for_plan_name(name)
        selected_count = int(usage.get("selected_count", 0) or 0)
        open_count = int(usage.get("open_count", 0) or 0)
        favorite_boost = 5 if name in favorites else 0
        usage_boost = min(selected_count, 5) + min(open_count, 3)
        recency = max(
            _recency_boost(str(usage.get("last_selected_at", "") or "")),
            _recency_boost(str(usage.get("last_opened_at", "") or "")),
        )
        score = favorite_boost + usage_boost + recency
        out.append(
            {
                "name": name,
                "intent": meta.get("intent", ""),
                "goal": meta.get("goal", ""),
                "tags": meta.get("tags", []) or [],
                "score": score,
                "score_breakdown": {
                    "favorite_boost": favorite_boost,
                    "usage_boost": usage_boost,
                    "recency_boost": recency,
                },
            }
        )
    out.sort(key=lambda x: (int(x.get("score", 0)), str(x.get("name", ""))), reverse=True)
    return {"status": "ok", "top_plans": out[:10]}


def _daily_plan_payload(cluster: str = "", namespace: str = "", environment: str = "") -> dict:
    plans_meta = _list_plans()
    if not plans_meta:
        return {"status": "ok", "daily_plan": None, "reason": "sem planos ativos na biblioteca"}

    favorites = _favorite_names_set()
    best = None
    for meta in plans_meta:
        name = str(meta.get("name", "") or "")
        usage = _usage_for_plan_name(name)
        selected_count = int(usage.get("selected_count", 0) or 0)
        open_count = int(usage.get("open_count", 0) or 0)
        suggest_count = int(usage.get("suggest_count", 0) or 0)
        favorite_boost = 6 if name in favorites else 0
        recency_boost = max(
            _recency_boost(str(usage.get("last_selected_at", "") or "")),
            _recency_boost(str(usage.get("last_opened_at", "") or "")),
            _recency_boost(str(usage.get("last_suggested_at", "") or "")),
        )
        usage_points = min(selected_count, 8) + min(open_count, 5) + min(suggest_count, 3)
        ctx = meta.get("context", {}) or {}
        context_boost = 0
        context_match = {}
        for key, wanted, plus, minus in (
            ("cluster", cluster.strip(), 4, -2),
            ("namespace", namespace.strip(), 3, -2),
            ("environment", environment.strip(), 5, -3),
        ):
            if not wanted:
                continue
            have = str(ctx.get(key, "") or "").strip()
            if not have:
                context_match[key] = "missing"
                continue
            if have == wanted:
                context_boost += plus
                context_match[key] = "match"
            else:
                context_boost += minus
                context_match[key] = "mismatch"
        score = favorite_boost + usage_points + recency_boost + context_boost
        reason_parts = []
        if favorite_boost:
            reason_parts.append("favorito")
        if usage_points:
            reason_parts.append("uso")
        if recency_boost:
            reason_parts.append("recencia")
        if context_boost > 0:
            reason_parts.append("contexto")
        reason = " + ".join(reason_parts) if reason_parts else "fallback por disponibilidade"
        row = {
            "name": name,
            "intent": meta.get("intent", ""),
            "goal": meta.get("goal", ""),
            "tags": meta.get("tags", []) or [],
            "score": score,
            "reason": reason,
            "score_parts": {
                "favorite_boost": favorite_boost,
                "usage_points": usage_points,
                "recency_boost": recency_boost,
                "context_boost": context_boost,
            },
            "context_match": context_match,
        }
        if best is None or int(row["score"]) > int(best["score"]):
            best = row

    if best is None:
        fallback = sorted(plans_meta, key=lambda p: str(p.get("mtime", "")), reverse=True)[0]
        best = {
            "name": fallback.get("name", ""),
            "intent": fallback.get("intent", ""),
            "goal": fallback.get("goal", ""),
            "tags": fallback.get("tags", []) or [],
            "score": 0,
            "reason": "fallback por plano mais recente",
            "score_parts": {"favorite_boost": 0, "usage_points": 0, "recency_boost": 0},
        }
    return {"status": "ok", "daily_plan": best}


def _render_daily_plan_text(payload: dict) -> None:
    row = payload.get("daily_plan")
    if not isinstance(row, dict) or not row:
        print("Nao foi possivel recomendar plano do dia.")
        print(f"Motivo: {payload.get('reason', 'dados insuficientes')}")
        return
    print("Plano recomendado do dia:")
    print(f"- nome: {row.get('name', '')}")
    print(f"- intent: {row.get('intent', '') or '(sem intent)'}")
    print(f"- goal: {row.get('goal', '') or '(sem goal)'}")
    tags = row.get("tags", []) or []
    print(f"- tags: {','.join(str(t) for t in tags) if tags else '(sem tags)'}")
    print(f"- score: {row.get('score', 0)}")
    print(f"- motivo: {row.get('reason', '')}")
    sb = row.get("score_parts", {}) or {}
    if sb:
        print(
            f"- score_parts: fav={sb.get('favorite_boost', 0)} usage={sb.get('usage_points', 0)} recency={sb.get('recency_boost', 0)} context={sb.get('context_boost', 0)}"
        )


def _latest_history_mtime_for_plan(plan_name: str) -> str:
    latest = ""
    for row in _list_history_entries():
        name = str(row.get("name", "") or "")
        if name.startswith(plan_name + ".") and name.endswith(".bak"):
            m = str(row.get("mtime", "") or "")
            if m and m > latest:
                latest = m
    return latest


def _stale_plans_payload() -> dict:
    plans = _list_plans()
    out: list[dict] = []
    now = datetime.now()
    for meta in plans:
        name = str(meta.get("name", "") or "")
        usage = _usage_for_plan_name(name)
        open_count = int(usage.get("open_count", 0) or 0)
        selected_count = int(usage.get("selected_count", 0) or 0)
        suggest_count = int(usage.get("suggest_count", 0) or 0)
        usage_score = open_count + selected_count + suggest_count
        if usage_score < 8:
            continue

        mtime_s = str(meta.get("mtime", "") or "")
        try:
            mtime_dt = datetime.fromisoformat(mtime_s)
            age_hours = (now - mtime_dt).total_seconds() / 3600.0
        except Exception:
            age_hours = 9999.0

        last_hist_s = _latest_history_mtime_for_plan(name)
        if last_hist_s:
            try:
                last_hist_dt = datetime.fromisoformat(last_hist_s)
                hist_age_hours = (now - last_hist_dt).total_seconds() / 3600.0
            except Exception:
                hist_age_hours = 9999.0
        else:
            hist_age_hours = 9999.0

        stale_by_old_file = age_hours >= 24
        stale_by_refresh_gap = hist_age_hours >= 0.1  # sem versionamento recente (~6min)
        if not (stale_by_old_file or stale_by_refresh_gap):
            continue

        if stale_by_old_file and stale_by_refresh_gap:
            reason = "muito usado, arquivo antigo e sem refresh/versionamento recente"
        elif stale_by_old_file:
            reason = "muito usado e arquivo antigo"
        else:
            reason = "muito usado e sem refresh/versionamento recente"

        out.append(
            {
                "name": name,
                "usage_score": usage_score,
                "last_modified": mtime_s,
                "last_history": last_hist_s,
                "reason": reason,
                "action_hint": {
                    "show": f"./scripts/livecopilot-k8s --show-plan {name}",
                    "copy": f"./scripts/livecopilot-k8s --copy-plan {name} --to {name}",
                },
            }
        )

    return {"status": "ok", "stale_plans": out}


def _render_stale_plans_text(payload: dict) -> None:
    rows = payload.get("stale_plans", []) or []
    if not rows:
        print("(nenhum plano stale detectado)")
        return
    for row in rows:
        print(f"- {row.get('name', '')}")
        print(f"  usage_score: {row.get('usage_score', 0)}")
        print(f"  last_modified: {row.get('last_modified', '')}")
        print(f"  motivo: {row.get('reason', '')}")
        hint = row.get("action_hint", {}) or {}
        if hint:
            print(f"  sugestao: {hint.get('show', '')}")
            print(f"  sugestao2: {hint.get('copy', '')}")


def _render_top_plans_text(payload: dict) -> None:
    rows = payload.get("top_plans", []) or []
    if not rows:
        print("(sem planos para ranking)")
        return
    for item in rows:
        print(f"- {item.get('name', '')} | score={item.get('score', 0)}")
        print(f"  intent: {item.get('intent', '') or '(sem intent)'}")


def _tokenize_text(raw: str) -> list[str]:
    return [t for t in re.findall(r"[a-z0-9_]+", (raw or "").lower()) if t]


def _score_plan_suggestion(
    query: str,
    meta: dict,
    favorite_names: set[str],
    usage_row: dict,
    *,
    cluster: str = "",
    namespace: str = "",
    environment: str = "",
) -> tuple[int, dict]:
    q = query.strip().lower()
    q_tokens = set(_tokenize_text(q))
    name = str(meta.get("name", "") or "").lower()
    intent = str(meta.get("intent", "") or "").lower()
    goal = str(meta.get("goal", "") or "").lower()
    plan_query = str(meta.get("query", "") or "").lower()
    tags = [str(t).strip().lower() for t in (meta.get("tags", []) or []) if str(t).strip()]

    score = 0
    breakdown = {"intent": 0, "tags": 0, "query": 0, "name": 0, "free": 0}

    # Intent match using inferred intent from user text.
    inferred_intent, _ = _infer_intent(query)
    inferred_intent_l = inferred_intent.lower()
    if inferred_intent_l and (inferred_intent_l in intent or intent in inferred_intent_l):
        score += 6
        breakdown["intent"] += 6

    # Tag match.
    tag_hits = sum(1 for t in tags if t in q_tokens or t in q)
    if tag_hits:
        points = min(6, tag_hits * 2)
        score += points
        breakdown["tags"] += points

    # Stored query match.
    plan_tokens = set(_tokenize_text(plan_query))
    shared_query = len(q_tokens.intersection(plan_tokens))
    if shared_query:
        points = min(5, shared_query)
        score += points
        breakdown["query"] += points
    if q and plan_query and (q in plan_query or plan_query in q):
        score += 3
        breakdown["query"] += 3

    # Name match.
    name_tokens = set(_tokenize_text(name))
    shared_name = len(q_tokens.intersection(name_tokens))
    if shared_name:
        points = min(4, shared_name)
        score += points
        breakdown["name"] += points
    if q and q in name:
        score += 2
        breakdown["name"] += 2

    # Goal/free text match.
    goal_tokens = set(_tokenize_text(goal))
    shared_goal = len(q_tokens.intersection(goal_tokens))
    if shared_goal:
        points = min(4, shared_goal)
        score += points
        breakdown["free"] += points

    text_match = int(score)

    favorite_boost = 5 if str(meta.get("name", "") or "") in favorite_names else 0
    selected_count = int(usage_row.get("selected_count", 0) or 0)
    open_count = int(usage_row.get("open_count", 0) or 0)
    usage_boost = min(selected_count, 5) + min(open_count, 3)
    recency_boost = max(
        _recency_boost(str(usage_row.get("last_selected_at", "") or "")),
        _recency_boost(str(usage_row.get("last_opened_at", "") or "")),
    )

    final_score = text_match + favorite_boost + usage_boost + recency_boost
    breakdown["text_match"] = text_match
    breakdown["favorite_boost"] = favorite_boost
    breakdown["usage_boost"] = usage_boost
    breakdown["recency_boost"] = recency_boost
    inferred_intent, _ = _infer_intent(query)
    pin = _pinned_plan_for_intent(inferred_intent)
    pin_boost = 0
    if pin and str(pin.get("plan_name", "") or "") == str(meta.get("name", "") or ""):
        pin_boost = 30
    breakdown["pin_boost"] = pin_boost
    final_score += pin_boost

    ctx = meta.get("context", {}) or {}
    context_boost = 0
    context_match = {}
    for key, wanted, plus, minus in (
        ("cluster", cluster.strip(), 4, -2),
        ("namespace", namespace.strip(), 3, -2),
        ("environment", environment.strip(), 5, -3),
    ):
        if not wanted:
            continue
        have = str(ctx.get(key, "") or "").strip()
        if not have:
            context_match[key] = "missing"
            continue
        if have == wanted:
            context_boost += plus
            context_match[key] = "match"
        else:
            context_boost += minus
            context_match[key] = "mismatch"
    breakdown["context_boost"] = context_boost
    breakdown["context_match"] = context_match
    final_score += context_boost

    inferred_incident = _infer_incident_type_from_query(query)
    plan_incident = str(meta.get("incident_type", "") or "").strip().lower()
    incident_boost = 0
    if plan_incident and plan_incident == inferred_incident:
        incident_boost = 4
    breakdown["incident_boost"] = incident_boost
    breakdown["inferred_incident_type"] = inferred_incident
    final_score += incident_boost

    if bool(meta.get("deprecated", False)):
        final_score -= 100
        breakdown["deprecated_penalty"] = -100
    else:
        breakdown["deprecated_penalty"] = 0
    return final_score, breakdown


def _deprecate_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    now_iso = datetime.now().isoformat(timespec="seconds")
    raw = path.read_text(encoding="utf-8", errors="replace")
    changed = False
    if path.suffix.lower() == ".json":
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            data = {}
        if not isinstance(data, dict):
            data = {}
        if not bool(data.get("deprecated", False)):
            data["deprecated"] = True
            data["deprecated_at"] = now_iso
            changed = True
        payload_raw = json.dumps(data, ensure_ascii=False, indent=2) + "\n"
        if changed:
            path.write_text(payload_raw, encoding="utf-8")
    else:
        meta = _read_plan_metadata(path)
        if not bool(meta.get("deprecated", False)):
            raw = _rewrite_or_insert_header(raw, "Deprecated", "true")
            raw = _rewrite_or_insert_header(raw, "Deprecated-At", now_iso)
            path.write_text(raw, encoding="utf-8")
            changed = True

    return "ok", {"status": "ok", "plan": path.name, "deprecated": True, "deprecated_at": now_iso if changed else _read_plan_metadata(path).get("deprecated_at", ""), "changed": changed}


def _undeprecate_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    raw = path.read_text(encoding="utf-8", errors="replace")
    changed = False
    if path.suffix.lower() == ".json":
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            data = {}
        if not isinstance(data, dict):
            data = {}
        if bool(data.get("deprecated", False)) or data.get("deprecated_at"):
            data["deprecated"] = False
            data.pop("deprecated_at", None)
            changed = True
            path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    else:
        meta = _read_plan_metadata(path)
        if bool(meta.get("deprecated", False)) or str(meta.get("deprecated_at", "") or "").strip():
            raw = _rewrite_or_insert_header(raw, "Deprecated", "false")
            raw = _remove_header(raw, "Deprecated-At")
            path.write_text(raw, encoding="utf-8")
            changed = True

    return "ok", {"status": "ok", "plan": path.name, "deprecated": False, "changed": changed}


def _list_deprecated_plans() -> list[dict]:
    rows = []
    for p in _list_plans():
        if bool(p.get("deprecated", False)):
            rows.append(p)
    return rows


def _set_plan_context(plan_name: str, cluster: str, namespace: str, environment: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    updates = {}
    if cluster.strip():
        updates["cluster"] = cluster.strip()
    if namespace.strip():
        updates["namespace"] = namespace.strip()
    if environment.strip():
        updates["environment"] = environment.strip()
    if not updates:
        return "error", {"status": "error", "error": "informe ao menos um contexto: --cluster/--namespace/--environment"}

    raw = path.read_text(encoding="utf-8", errors="replace")
    final_ctx = {}
    if path.suffix.lower() == ".json":
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            data = {}
        if not isinstance(data, dict):
            data = {}
        cur_ctx = data.get("context", {})
        if not isinstance(cur_ctx, dict):
            cur_ctx = {}
        for k, v in updates.items():
            cur_ctx[k] = v
        data["context"] = cur_ctx
        final_ctx = {k: str(v) for k, v in cur_ctx.items() if str(v).strip()}
        path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    else:
        text = raw
        if "cluster" in updates:
            text = _rewrite_or_insert_header(text, "Cluster", updates["cluster"])
        if "namespace" in updates:
            text = _rewrite_or_insert_header(text, "Namespace", updates["namespace"])
        if "environment" in updates:
            text = _rewrite_or_insert_header(text, "Environment", updates["environment"])
        path.write_text(text, encoding="utf-8")
        final_ctx = _read_plan_metadata(path).get("context", {}) or {}

    return "ok", {"status": "ok", "plan": path.name, "context": final_ctx}


def _show_plan_context(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}
    meta = _read_plan_metadata(path)
    ctx = meta.get("context", {}) or {}
    return "ok", {"status": "ok", "plan": path.name, "context": ctx}


def _set_incident_type(plan_name: str, incident_type: str) -> tuple[str, dict]:
    wanted = incident_type.strip().lower()
    if wanted not in ALLOWED_INCIDENT_TYPES:
        return "error", {"status": "error", "error": f"incident_type invalido: {incident_type}", "allowed": sorted(ALLOWED_INCIDENT_TYPES)}
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    raw = path.read_text(encoding="utf-8", errors="replace")
    if path.suffix.lower() == ".json":
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            data = {}
        if not isinstance(data, dict):
            data = {}
        data["incident_type"] = wanted
        path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    else:
        raw = _rewrite_or_insert_header(raw, "Incident-Type", wanted)
        path.write_text(raw, encoding="utf-8")
    return "ok", {"status": "ok", "plan": path.name, "incident_type": wanted}


def _list_by_incident_type_payload() -> dict:
    rows = _list_plans()
    grouped: dict[str, list[dict]] = {k: [] for k in sorted(ALLOWED_INCIDENT_TYPES)}
    grouped["(sem incidente)"] = []
    for p in rows:
        it = str(p.get("incident_type", "") or "").strip().lower()
        key = it if it in ALLOWED_INCIDENT_TYPES else "(sem incidente)"
        grouped.setdefault(key, []).append(
            {
                "name": p.get("name", ""),
                "intent": p.get("intent", ""),
                "goal": p.get("goal", ""),
            }
        )
    return {"status": "ok", "by_incident_type": grouped}


def _render_list_by_incident_type_text(payload: dict) -> None:
    grouped = payload.get("by_incident_type", {}) or {}
    for key in sorted(grouped.keys()):
        print(f"[{key}]")
        items = grouped.get(key, []) or []
        if not items:
            print("- (nenhum)")
            continue
        for it in items:
            print(f"- {it.get('name', '')} | intent={it.get('intent', '') or '(sem intent)'}")


def _infer_incident_type_from_query(query: str) -> str:
    q = query.lower()
    if any(k in q for k in ["crashloop", "logs", "debug", "describe pod"]):
        return "debug"
    if any(k in q for k in ["restart deployment", "rollout", "deployment"]):
        return "rollout"
    if "namespace" in q:
        return "namespace"
    if any(k in q for k in ["serviceaccount", "token", "rbac", "auth"]):
        return "auth"
    if any(k in q for k in ["networkpolicy", "cni", "dns", "ingress", "egress"]):
        return "networking"
    if any(k in q for k in ["pvc", "volume", "storageclass"]):
        return "storage"
    if any(k in q for k in ["events", "metrics", "prometheus", "observability"]):
        return "observability"
    return "generic"


def _suggested_plan_name_from_query(query: str) -> str:
    tokens = _tokenize_text(query)
    if not tokens:
        return "plan_novo.json"
    slug = "_".join(tokens[:8])
    return f"plan_{slug}.json"


def _should_suggest_new_plan(suggestions: list[dict]) -> bool:
    if not suggestions:
        return True
    top1 = int(suggestions[0].get("score", 0) or 0)
    top2 = int(suggestions[1].get("score", 0) or 0) if len(suggestions) > 1 else 0
    gap = top1 - top2
    sb = suggestions[0].get("score_breakdown", {}) or {}
    top1_text = int(sb.get("text_match", 0) or 0)
    if top1_text < 2:
        return True
    if top1 < 8:
        return True
    if top1 < 10 and gap < 2:
        return True
    return False


def _suggest_plans(
    query: str,
    limit: int = 3,
    *,
    cluster: str = "",
    namespace: str = "",
    environment: str = "",
    incident_type: str = "",
) -> dict:
    plans = _list_plans()
    favorite_names = _favorite_names_set()
    scored: list[dict] = []
    for meta in plans:
        if incident_type.strip():
            if str(meta.get("incident_type", "") or "").strip().lower() != incident_type.strip().lower():
                continue
        usage_row = _usage_for_plan_name(str(meta.get("name", "") or ""))
        score, breakdown = _score_plan_suggestion(
            query,
            meta,
            favorite_names,
            usage_row,
            cluster=cluster,
            namespace=namespace,
            environment=environment,
        )
        if score <= 0:
            continue
        scored.append(
            {
                "name": meta.get("name", ""),
                "intent": meta.get("intent", ""),
                "goal": meta.get("goal", ""),
                "tags": meta.get("tags", []) or [],
                "score": score,
                "score_breakdown": breakdown,
            }
        )
    scored.sort(key=lambda x: (int(x.get("score", 0)), str(x.get("name", ""))), reverse=True)
    suggestions = scored[:limit]
    if _should_suggest_new_plan(suggestions):
        suggested_name = _suggested_plan_name_from_query(query)
        next_cmd = f'./scripts/livecopilot-k8s --mode plan --save-plan {suggested_name} "{query}"'
        return {
            "status": "ok",
            "query": query,
            "suggestions": [],
            "suggest_new_plan": True,
            "suggested_plan_name": suggested_name,
            "next_step_command": next_cmd,
        }
    return {"status": "ok", "query": query, "suggestions": suggestions, "suggest_new_plan": False}


def _render_suggestions_text(payload: dict) -> None:
    query = str(payload.get("query", "") or "")
    suggestions = payload.get("suggestions", []) or []
    if payload.get("suggest_new_plan"):
        print("Nao ha plano suficientemente bom para esta consulta.")
        print("Sugestao: criar novo plano.")
        print(f"Nome sugerido: {payload.get('suggested_plan_name', 'plan_novo.json')}")
        next_cmd = str(payload.get("next_step_command", "") or "").strip()
        if next_cmd:
            print(f"Proximo passo: {next_cmd}")
        return
    print(f"Query: {query}")
    if not suggestions:
        print("Nenhuma sugestao de plano encontrada.")
        return
    for item in suggestions[:3]:
        tags = item.get("tags", []) or []
        print(f"- {item.get('name', '')}")
        print(f"  intent: {item.get('intent', '') or '(sem intent)'}")
        print(f"  goal: {item.get('goal', '') or '(sem goal)'}")
        print(f"  score: {item.get('score', 0)}")
        sb = item.get("score_breakdown", {}) or {}
        if isinstance(sb, dict):
            print(
                f"  score_parts: text={sb.get('text_match', 0)} fav={sb.get('favorite_boost', 0)} usage={sb.get('usage_boost', 0)} recency={sb.get('recency_boost', 0)}"
            )
        print(f"  tags: {','.join(str(t) for t in tags) if tags else '(sem tags)'}")


def _open_suggested_plan(query: str, *, cluster: str = "", namespace: str = "", environment: str = "") -> tuple[str, dict]:
    suggested = _suggest_plans(query=query, limit=5, cluster=cluster, namespace=namespace, environment=environment)
    if suggested.get("suggest_new_plan"):
        return "ok", {
            "status": "ok",
            "query": query,
            "suggestions": [],
            "suggest_new_plan": True,
            "suggested_plan_name": suggested.get("suggested_plan_name", "plan_novo.json"),
            "next_step_command": suggested.get("next_step_command", ""),
        }
    suggestions = suggested.get("suggestions", []) or []
    if not suggestions:
        return "error", {"status": "error", "error": "no suggestions found", "query": query, "candidates": []}

    top1 = suggestions[0]
    top2 = suggestions[1] if len(suggestions) > 1 else None
    top1_score = int(top1.get("score", 0))
    top2_score = int(top2.get("score", 0)) if top2 else -1
    clear_choice = top2 is None or top1_score >= (top2_score + 3)

    if not clear_choice:
        return "error", {
            "status": "error",
            "error": "ambiguous suggestion",
            "decision": "ambiguous",
            "reason": f"top1 score={top1_score}, top2 score={top2_score}: diferenca insuficiente",
            "query": query,
            "candidates": suggestions[:3],
        }

    status, path, candidates = _resolve_show_plan(str(top1.get("name", "")))
    if status != "ok" or path is None:
        if status == "ambiguous":
            return "error", {"status": "error", "error": "ambiguous suggestion", "query": query, "candidates": candidates}
        return "error", {"status": "error", "error": f"plano nao encontrado: {top1.get('name', '')}"}

    plan = _load_show_plan(path)
    reason = f"top1 score={top1_score}"
    if top2 is not None:
        reason += f", top2 score={top2_score}"
    return "ok", {
        "status": "ok",
        "query": query,
        "decision": "selected",
        "selected_plan": {"name": top1.get("name", ""), "score": top1_score},
        "reason": reason,
        "plan": plan,
    }


def _explain_suggestion(query: str, *, cluster: str = "", namespace: str = "", environment: str = "") -> dict:
    payload = _suggest_plans(query=query, limit=5, cluster=cluster, namespace=namespace, environment=environment)
    suggestions = payload.get("suggestions", []) or []
    if payload.get("suggest_new_plan"):
        return {
            "status": "ok",
            "query": query,
            "candidates": [],
            "decision": "ambiguous",
            "reason": "nenhum plano suficientemente bom",
            "suggest_new_plan": True,
            "suggested_plan_name": payload.get("suggested_plan_name", ""),
            "next_step_command": payload.get("next_step_command", ""),
        }
    if not suggestions:
        return {"status": "ok", "query": query, "candidates": [], "decision": "ambiguous", "reason": "sem candidatos"}

    top1 = suggestions[0]
    top2 = suggestions[1] if len(suggestions) > 1 else None
    top1_score = int(top1.get("score", 0) or 0)
    top2_score = int(top2.get("score", 0) or 0) if top2 else -1
    if top2 is None or top1_score >= (top2_score + 3):
        decision = "selected"
        reason = f"{top1.get('name', '')} venceu por score ({top1_score}) com diferenca segura para o segundo"
    else:
        decision = "ambiguous"
        reason = f"candidatos muito proximos: top1={top1_score}, top2={top2_score}"
    return {
        "status": "ok",
        "query": query,
        "candidates": [
            {"name": s.get("name", ""), "score": s.get("score", 0), "score_breakdown": s.get("score_breakdown", {})}
            for s in suggestions[:5]
        ],
        "decision": decision,
        "reason": reason,
    }


def _render_explain_suggestion_text(payload: dict) -> None:
    print(f"Query: {payload.get('query', '')}")
    print(f"Decision: {payload.get('decision', '')}")
    print(f"Reason: {payload.get('reason', '')}")
    for item in payload.get("candidates", []) or []:
        print(f"- {item.get('name', '')} | score={item.get('score', 0)}")
        sb = item.get("score_breakdown", {}) or {}
        print(
            f"  parts: text={sb.get('text_match', 0)} pin={sb.get('pin_boost', 0)} fav={sb.get('favorite_boost', 0)} usage={sb.get('usage_boost', 0)} recency={sb.get('recency_boost', 0)} context={sb.get('context_boost', 0)} deprecated={sb.get('deprecated_penalty', 0)}"
        )


def _render_open_suggested_text(payload: dict) -> None:
    if payload.get("suggest_new_plan"):
        print(f"Query: {payload.get('query', '')}")
        print("Nao ha plano suficientemente bom para abrir automaticamente.")
        print(f"Sugestao: criar novo plano ({payload.get('suggested_plan_name', 'plan_novo.json')}).")
        next_cmd = str(payload.get("next_step_command", "") or "").strip()
        if next_cmd:
            print(f"Proximo passo: {next_cmd}")
        return
    print(f"Query: {payload.get('query', '')}")
    sel = payload.get("selected_plan", {}) or {}
    print(f"Plano escolhido: {sel.get('name', '')} (score={sel.get('score', 0)})")
    print(f"Motivo: {payload.get('reason', '')}")
    _render_show_plan_text(payload.get("plan", {}) or {})


def _build_ops_index() -> dict:
    DEFAULT_CATALOG_DIR.mkdir(parents=True, exist_ok=True)
    plans = _list_plans()
    by_intent: dict[str, list[dict]] = {}
    by_tag: dict[str, list[dict]] = {}

    for p in plans:
        name = str(p.get("name", "") or "")
        intent = str(p.get("intent", "") or "").strip() or "(sem intent)"
        goal = str(p.get("goal", "") or "").strip()
        tags = [str(t).strip().lower() for t in (p.get("tags", []) or []) if str(t).strip()]

        by_intent.setdefault(intent, []).append({"name": name, "tags": tags, "goal": goal})
        if not tags:
            by_tag.setdefault("(sem tags)", []).append({"name": name, "intent": intent, "goal": goal})
        else:
            for tag in tags:
                by_tag.setdefault(tag, []).append({"name": name, "intent": intent, "goal": goal})

    for k in by_intent:
        by_intent[k] = sorted(by_intent[k], key=lambda x: str(x.get("name", "")))
    for k in by_tag:
        by_tag[k] = sorted(by_tag[k], key=lambda x: str(x.get("name", "")))

    ops_json = {
        "generated_at": datetime.now().isoformat(timespec="seconds"),
        "by_intent": dict(sorted(by_intent.items(), key=lambda x: x[0].lower())),
        "by_tag": dict(sorted(by_tag.items(), key=lambda x: x[0].lower())),
    }

    json_path = DEFAULT_CATALOG_DIR / "ops_index.json"
    md_path = DEFAULT_CATALOG_DIR / "ops_index.md"
    json_path.write_text(json.dumps(ops_json, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

    lines = ["# Livecopilot Operational Index", "", "## By Intent", ""]
    for intent, items in ops_json["by_intent"].items():
        lines.append(f"### {intent}")
        for item in items:
            lines.append(f"- {item.get('name', '')}")
        lines.append("")
    lines.extend(["## By Tag", ""])
    for tag, items in ops_json["by_tag"].items():
        lines.append(f"### {tag}")
        for item in items:
            lines.append(f"- {item.get('name', '')}")
        lines.append("")
    md_path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")

    return {
        "status": "ok",
        "catalog_dir": str(DEFAULT_CATALOG_DIR),
        "ops_index_json": str(json_path),
        "ops_index_md": str(md_path),
        "intents": len(ops_json["by_intent"]),
        "tags": len(ops_json["by_tag"]),
    }


def _template_for_incident(incident_type: str) -> dict:
    it = incident_type.strip().lower()
    title_map = {
        "debug": "Debug de workload Kubernetes",
        "rollout": "Rollout controlado de deployment",
        "namespace": "Operacao de namespace Kubernetes",
        "auth": "Diagnostico de autenticacao e RBAC",
        "networking": "Diagnostico de conectividade e rede",
        "storage": "Diagnostico de volumes e armazenamento",
        "observability": "Coleta de sinais de observabilidade",
        "generic": "Runbook operacional generico",
    }
    goal_map = {
        "debug": "Identificar causa raiz do incidente e registrar evidencias.",
        "rollout": "Executar mudanca com verificacao de saude e rollback preparado.",
        "namespace": "Criar/ajustar namespace com validacoes de isolamento.",
        "auth": "Validar permissoes, credenciais e escopo de acesso.",
        "networking": "Validar conectividade, DNS e politicas de rede.",
        "storage": "Validar volumes, claims e capacidade antes de acao corretiva.",
        "observability": "Coletar metricas, eventos e logs para suporte a decisao.",
        "generic": "Executar troubleshooting incremental com checkpoints claros.",
    }
    commands_map = {
        "debug": ["kubectl describe pod <pod>", "kubectl logs <pod> --previous", "kubectl get events --sort-by=.lastTimestamp"],
        "rollout": ["kubectl get deployment <nome>", "kubectl rollout restart deployment <nome>", "kubectl rollout status deployment <nome>"],
        "namespace": ["kubectl get namespace <nome>", "kubectl create namespace <nome>", "kubectl get resourcequota -n <nome>"],
        "auth": ["kubectl auth can-i get pods -n <namespace>", "kubectl get sa -n <namespace>", "kubectl describe rolebinding -n <namespace>"],
        "networking": ["kubectl get svc -n <namespace>", "kubectl get endpoints -n <namespace>", "kubectl get networkpolicy -n <namespace>"],
        "storage": ["kubectl get pvc -n <namespace>", "kubectl describe pvc <nome> -n <namespace>", "kubectl get pv"],
        "observability": ["kubectl top pods -n <namespace>", "kubectl get events --sort-by=.lastTimestamp -n <namespace>", "kubectl logs <pod> -n <namespace>"],
        "generic": ["kubectl get pods -A", "kubectl describe pod <pod>", "kubectl get events --sort-by=.lastTimestamp"],
    }
    return {
        "incident_type": it,
        "title_template": title_map.get(it, "Runbook operacional"),
        "goal_template": goal_map.get(it, "Executar diagnostico incremental com seguranca operacional."),
        "prechecks": ["Confirmar contexto (cluster/namespace/environment).", "Validar alvo e impacto esperado."],
        "commands": commands_map.get(it, commands_map["generic"]),
        "validation": ["Confirmar estado final do recurso.", "Registrar evidencias (eventos/logs)."],
        "notes": ["Nao executar acao destrutiva sem janela aprovada.", "Nao assumir sucesso sem validacao explicita."],
        "required_sections": ["title", "goal", "prechecks", "commands", "validation", "notes"],
    }


def _build_templates() -> dict:
    DEFAULT_TEMPLATES_DIR.mkdir(parents=True, exist_ok=True)
    generated: list[str] = []
    for it in sorted(ALLOWED_INCIDENT_TYPES):
        template = _template_for_incident(it)
        path = DEFAULT_TEMPLATES_DIR / f"{it}_template.json"
        path.write_text(json.dumps(template, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
        generated.append(str(path))

    catalog_path = DEFAULT_TEMPLATES_DIR / "templates_catalog.md"
    lines = ["# Templates por Incident Type", ""]
    for it in sorted(ALLOWED_INCIDENT_TYPES):
        lines.append(f"- {it}: {it}_template.json")
    catalog_path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    return {"status": "ok", "templates_dir": str(DEFAULT_TEMPLATES_DIR), "templates": generated, "catalog_md": str(catalog_path)}


def _load_incident_template(incident_type: str) -> tuple[str, dict]:
    it = incident_type.strip().lower()
    if it not in ALLOWED_INCIDENT_TYPES:
        return "error", {"status": "error", "error": f"incident_type invalido: {incident_type}", "allowed": sorted(ALLOWED_INCIDENT_TYPES)}
    path = DEFAULT_TEMPLATES_DIR / f"{it}_template.json"
    if not path.exists():
        return "error", {"status": "error", "error": f"template nao encontrado: {path}", "hint": "rode --build-templates"}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        return "error", {"status": "error", "error": f"falha ao ler template: {exc}"}
    if not isinstance(data, dict):
        return "error", {"status": "error", "error": "template invalido"}
    return "ok", {"status": "ok", "template": data, "template_path": str(path)}


def _new_plan_from_template(
    incident_type: str,
    name: str,
    *,
    goal: str = "",
    title: str = "",
    tags: str = "",
    cluster: str = "",
    namespace: str = "",
    environment: str = "",
) -> tuple[str, dict]:
    load_status, load_payload = _load_incident_template(incident_type)
    if load_status != "ok":
        return "error", load_payload
    file_name = name.strip()
    if not file_name:
        return "error", {"status": "error", "error": "informe --name para criar plano por template"}
    out_path = _resolve_plan_path(file_name)
    if out_path.exists():
        return "error", {"status": "error", "error": f"destino ja existe: {out_path}"}

    template = load_payload.get("template", {}) or {}
    tags_list = _parse_tags(tags)
    plan = {
        "title": title.strip() or str(template.get("title_template", "") or ""),
        "intent": str(template.get("title_template", "") or ""),
        "incident_type": incident_type.strip().lower(),
        "goal": goal.strip() or str(template.get("goal_template", "") or ""),
        "query": "",
        "tags": tags_list,
        "prechecks": [str(x) for x in (template.get("prechecks", []) or []) if str(x).strip()],
        "commands": [str(x) for x in (template.get("commands", []) or []) if str(x).strip()],
        "validation": [str(x) for x in (template.get("validation", []) or []) if str(x).strip()],
        "notes": [str(x) for x in (template.get("notes", []) or []) if str(x).strip()],
        "required_sections": [str(x) for x in (template.get("required_sections", []) or []) if str(x).strip()],
    }
    ctx = {}
    if cluster.strip():
        ctx["cluster"] = cluster.strip()
    if namespace.strip():
        ctx["namespace"] = namespace.strip()
    if environment.strip():
        ctx["environment"] = environment.strip()
    if ctx:
        plan["context"] = ctx

    if out_path.suffix.lower() == ".txt":
        lines = [
            f"Title: {plan.get('title', '')}",
            f"Incident-Type: {plan.get('incident_type', '')}",
            f"Goal: {plan.get('goal', '')}",
        ]
        if tags_list:
            lines.append(f"Tags: {','.join(tags_list)}")
        if ctx.get("cluster"):
            lines.append(f"Cluster: {ctx.get('cluster', '')}")
        if ctx.get("namespace"):
            lines.append(f"Namespace: {ctx.get('namespace', '')}")
        if ctx.get("environment"):
            lines.append(f"Environment: {ctx.get('environment', '')}")
        lines.extend(["", "## Prechecks"])
        for item in plan.get("prechecks", []):
            lines.append(f"- {item}")
        lines.extend(["", "## Commands"])
        for item in plan.get("commands", []):
            lines.append(f"- {item}")
        lines.extend(["", "## Validation"])
        for item in plan.get("validation", []):
            lines.append(f"- {item}")
        lines.extend(["", "## Notes"])
        for item in plan.get("notes", []):
            lines.append(f"- {item}")
        out_path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    else:
        out_path.write_text(json.dumps(plan, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")

    return "ok", {
        "status": "ok",
        "created_plan": out_path.name,
        "template_used": Path(str(load_payload.get("template_path", ""))).name,
        "path": str(out_path),
    }


def _plan_sections_presence(path: Path, content_type: str, content: object) -> dict:
    present = set()
    if content_type == "json" and isinstance(content, dict):
        if str(content.get("title", "")).strip():
            present.add("title")
        if str(content.get("goal", "")).strip():
            present.add("goal")
        for sec in ("prechecks", "commands", "validation", "notes"):
            val = content.get(sec)
            if isinstance(val, list) and any(str(x).strip() for x in val):
                present.add(sec)
    else:
        raw = path.read_text(encoding="utf-8", errors="replace")
        if re.search(r"^\s*title\s*:\s*.+$", raw, flags=re.IGNORECASE | re.MULTILINE):
            present.add("title")
        if re.search(r"^\s*goal\s*:\s*.+$", raw, flags=re.IGNORECASE | re.MULTILINE):
            present.add("goal")
        if re.search(r"^\s*##\s*prechecks\b", raw, flags=re.IGNORECASE | re.MULTILINE):
            present.add("prechecks")
        if re.search(r"^\s*##\s*commands\b", raw, flags=re.IGNORECASE | re.MULTILINE):
            present.add("commands")
        if re.search(r"^\s*##\s*validation\b", raw, flags=re.IGNORECASE | re.MULTILINE):
            present.add("validation")
        if re.search(r"^\s*##\s*notes\b", raw, flags=re.IGNORECASE | re.MULTILINE):
            present.add("notes")
    return {"present": sorted(present)}


def _validate_plan(plan_name: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    plan = _load_show_plan(path)
    meta = _read_plan_metadata(path)
    incident_type = str(meta.get("incident_type", "") or "").strip().lower()
    present = []
    missing = []
    validation_status = "ok"

    if not incident_type:
        missing.append("incident_type")
    else:
        present.append("incident_type")

    sec_info = _plan_sections_presence(path, str(plan.get("content_type", "text")), plan.get("content"))
    present_sections = sec_info.get("present", []) or []
    present.extend(present_sections)

    if incident_type:
        t_status, t_payload = _load_incident_template(incident_type)
        if t_status != "ok":
            missing.append("template")
            validation_status = "fail"
        else:
            tpl = t_payload.get("template", {}) or {}
            required = [str(x).strip() for x in (tpl.get("required_sections", []) or []) if str(x).strip()]
            for sec in required:
                if sec not in present_sections:
                    missing.append(sec)
            if "commands" in required and "commands" not in present_sections:
                missing.append("commands_minimos")

    if not incident_type:
        validation_status = "fail"
    elif missing:
        validation_status = "warning"

    payload = {
        "status": "ok",
        "plan": path.name,
        "incident_type": incident_type,
        "validation_status": validation_status,
        "present": sorted(set(present)),
        "missing": sorted(set(missing)),
    }
    return "ok", payload


def _render_validate_plan_text(payload: dict) -> None:
    print(f"Plano: {payload.get('plan', '')}")
    print(f"Incident-Type: {payload.get('incident_type', '') or '(ausente)'}")
    print(f"Status: {payload.get('validation_status', '')}")
    present = payload.get("present", []) or []
    missing = payload.get("missing", []) or []
    print(f"Presentes: {', '.join(str(x) for x in present) if present else '(nenhum)'}")
    print(f"Ausentes: {', '.join(str(x) for x in missing) if missing else '(nenhum)'}")


def _stale_plan_names_set() -> set[str]:
    payload = _stale_plans_payload()
    out: set[str] = set()
    for row in payload.get("stale_plans", []) or []:
        name = str(row.get("name", "") or "").strip()
        if name:
            out.add(name)
    return out


def _resolve_refresh_output_path(raw_value: str) -> Path:
    out = Path(raw_value).expanduser()
    if len(out.parts) == 1:
        DEFAULT_MERGE_DIR.mkdir(parents=True, exist_ok=True)
        return DEFAULT_MERGE_DIR / out.name
    out.parent.mkdir(parents=True, exist_ok=True)
    return out


def _refresh_plan(plan_name: str, save_refresh: str = "") -> tuple[str, dict]:
    status, path, candidates = _resolve_show_plan(plan_name)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "nome ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    meta = _read_plan_metadata(path)
    incident_type = str(meta.get("incident_type", "") or "").strip().lower()
    stale = path.name in _stale_plan_names_set()

    validate_status, validate_payload = _validate_plan(path.name)
    if validate_status != "ok":
        return "error", validate_payload
    missing = [str(x) for x in (validate_payload.get("missing", []) or []) if str(x).strip()]

    refresh_suggestion: dict = {"use_template": False, "template": "", "actions": []}
    if incident_type in ALLOWED_INCIDENT_TYPES:
        t_status, t_payload = _load_incident_template(incident_type)
        if t_status == "ok":
            template = t_payload.get("template", {}) or {}
            refresh_suggestion["use_template"] = True
            refresh_suggestion["template"] = Path(str(t_payload.get("template_path", ""))).name
            actions: list[dict] = []
            for sec in missing:
                if sec in {"title", "goal", "prechecks", "commands", "validation", "notes"}:
                    val = template.get(sec if sec != "title" else "title_template", "")
                    actions.append({"section": sec, "suggested_content": val})
            if not actions:
                actions.append({"section": "refresh", "suggested_content": "revisar comandos e validacao com base no template atual"})
            refresh_suggestion["actions"] = actions
    if not refresh_suggestion.get("actions"):
        refresh_suggestion["actions"] = [{"section": "refresh", "suggested_content": "atualizar secoes ausentes manualmente"}]

    payload = {
        "status": "ok",
        "plan": path.name,
        "stale": stale,
        "incident_type": incident_type,
        "missing_sections": missing,
        "refresh_suggestion": refresh_suggestion,
    }

    if save_refresh.strip():
        out = _resolve_refresh_output_path(save_refresh.strip())
        if out.exists():
            return "error", {"status": "error", "error": f"destino ja existe: {out}"}
        out.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
        payload["saved_refresh"] = str(out)
    return "ok", payload


def _render_refresh_plan_text(payload: dict) -> None:
    print(f"Plano original: {payload.get('plan', '')}")
    print(f"Incident-Type: {payload.get('incident_type', '') or '(ausente)'}")
    print(f"Stale: {'true' if payload.get('stale') else 'false'}")
    missing = payload.get("missing_sections", []) or []
    print(f"Secoes faltantes: {', '.join(str(x) for x in missing) if missing else '(nenhuma)'}")
    print("Sugestoes de atualizacao:")
    rs = payload.get("refresh_suggestion", {}) or {}
    for item in rs.get("actions", []) or []:
        section = str(item.get("section", "") or "")
        content = item.get("suggested_content", "")
        if isinstance(content, list):
            content = "; ".join(str(x) for x in content[:3])
        print(f"- {section}: {content}")
    if payload.get("saved_refresh"):
        print(f"Refresh salvo em: {payload.get('saved_refresh', '')}")


def _load_duplicates_rows() -> list[dict]:
    dup_path = DEFAULT_CATALOG_DIR / "duplicates.json"
    if dup_path.exists():
        try:
            data = json.loads(dup_path.read_text(encoding="utf-8", errors="replace"))
            rows = data.get("duplicates", [])
            if isinstance(rows, list):
                return rows
        except Exception:
            pass
    return (_find_duplicates_payload().get("duplicates", []) or [])


def _usage_score_for_plan(name: str) -> int:
    row = _usage_for_plan_name(name)
    return int(row.get("open_count", 0) or 0) + int(row.get("selected_count", 0) or 0) + int(row.get("suggest_count", 0) or 0)


def _suggest_upgrade_payload() -> dict:
    deprecated = _list_deprecated_plans()
    active = [p for p in _list_plans() if not bool(p.get("deprecated", False))]
    dup_rows = _load_duplicates_rows()
    dup_map: dict[tuple[str, str], float] = {}
    for row in dup_rows:
        l = str(row.get("left", "") or "")
        r = str(row.get("right", "") or "")
        s = float(row.get("score", 0.0) or 0.0)
        if l and r:
            dup_map[(l, r)] = s
            dup_map[(r, l)] = s

    upgrades: list[dict] = []
    for dep in deprecated:
        dep_name = str(dep.get("name", "") or "")
        best = None
        dep_goal_tokens = set(_tokenize_text(str(dep.get("goal", "") or "")))
        dep_tags = set(str(t).strip().lower() for t in (dep.get("tags", []) or []) if str(t).strip())
        dep_inc = str(dep.get("incident_type", "") or "").strip().lower()
        dep_usage = _usage_score_for_plan(dep_name)

        for cand in active:
            cand_name = str(cand.get("name", "") or "")
            score = 0.0
            reasons: list[str] = []
            dup_score = float(dup_map.get((dep_name, cand_name), 0.0))
            if dup_score > 0:
                score += dup_score * 100.0
                reasons.append(f"duplicate_score={dup_score:.2f}")
            cand_inc = str(cand.get("incident_type", "") or "").strip().lower()
            if dep_inc and cand_inc and dep_inc == cand_inc:
                score += 20.0
                reasons.append("incident_type match")
            cand_tags = set(str(t).strip().lower() for t in (cand.get("tags", []) or []) if str(t).strip())
            if dep_tags and cand_tags:
                inter = len(dep_tags.intersection(cand_tags))
                union = len(dep_tags.union(cand_tags))
                if union:
                    tag_sim = inter / union
                    if tag_sim > 0:
                        score += tag_sim * 15.0
                        reasons.append(f"tags overlap={tag_sim:.2f}")
            cand_goal_tokens = set(_tokenize_text(str(cand.get("goal", "") or "")))
            if dep_goal_tokens and cand_goal_tokens:
                inter = len(dep_goal_tokens.intersection(cand_goal_tokens))
                union = len(dep_goal_tokens.union(cand_goal_tokens))
                if union:
                    goal_sim = inter / union
                    if goal_sim > 0:
                        score += goal_sim * 20.0
                        reasons.append(f"goal overlap={goal_sim:.2f}")
            cand_usage = _usage_score_for_plan(cand_name)
            if cand_usage > dep_usage:
                score += min(10.0, float(cand_usage - dep_usage))
                reasons.append("higher usage")
            cand_ctx = cand.get("context", {}) or {}
            dep_ctx = dep.get("context", {}) or {}
            if isinstance(cand_ctx, dict) and isinstance(dep_ctx, dict):
                match_ctx = 0
                for k in ("cluster", "namespace", "environment"):
                    if str(dep_ctx.get(k, "") or "").strip() and str(dep_ctx.get(k, "") or "").strip() == str(cand_ctx.get(k, "") or "").strip():
                        match_ctx += 1
                if match_ctx:
                    score += float(match_ctx * 2)
                    reasons.append("context match")
            row = {"replacement": cand_name, "score": round(score, 3), "reasons": reasons}
            if best is None or float(row["score"]) > float(best["score"]):
                best = row
        if best and float(best.get("score", 0.0)) > 0:
            upgrades.append(
                {
                    "deprecated": dep_name,
                    "replacement": best.get("replacement", ""),
                    "reason": " + ".join(best.get("reasons", [])[:3]) if best.get("reasons") else "similaridade local e sinais de uso",
                }
            )
    return {"status": "ok", "upgrades": upgrades}


def _render_suggest_upgrade_text(payload: dict) -> None:
    rows = payload.get("upgrades", []) or []
    if not rows:
        print("(nenhum upgrade sugerido)")
        return
    for row in rows:
        print(f"Plan deprecated: {row.get('deprecated', '')}")
        print(f"Suggested replacement: {row.get('replacement', '')}")
        print(f"Reason: {row.get('reason', '')}")


def _infer_incident_type_wizard(query: str) -> str:
    q = query.lower()
    if "crashloop" in q:
        return "debug"
    if "restart" in q:
        return "rollout"
    if "namespace" in q:
        return "namespace"
    if "auth" in q or "login" in q:
        return "auth"
    if "network" in q or "service" in q:
        return "networking"
    if "storage" in q or "pvc" in q:
        return "storage"
    if "metrics" in q or "log" in q:
        return "observability"
    return _infer_incident_type_from_query(query)


def _wizard_plan_payload(query: str) -> dict:
    clean_q = query.strip()
    incident_type = _infer_incident_type_wizard(clean_q)
    t_status, t_payload = _load_incident_template(incident_type)
    if t_status != "ok":
        return {"status": "error", "error": t_payload.get("error", "template nao encontrado"), "hint": "rode --build-templates"}
    template = t_payload.get("template", {}) or {}
    slug = "_".join(_tokenize_text(clean_q)[:6]) or "novo"
    suggested = f"plan_{incident_type}_{slug}.json"
    goal = str(template.get("goal_template", "") or f"Criar runbook para: {clean_q}")
    next_cmd = f'./scripts/livecopilot-k8s --new-plan-from-template {incident_type} --name {suggested} --goal "{goal}"'
    return {
        "status": "ok",
        "wizard": {
            "query": clean_q,
            "incident_type": incident_type,
            "suggested_plan": suggested,
            "goal": goal,
            "template_sections": [str(x) for x in (template.get("required_sections", []) or []) if str(x).strip()],
            "next_command": next_cmd,
        },
    }


def _render_wizard_plan_text(payload: dict) -> None:
    wiz = payload.get("wizard", {}) or {}
    print("Wizard suggestion:")
    print(f"incident_type: {wiz.get('incident_type', '')}")
    print(f"suggested_name: {wiz.get('suggested_plan', '')}")
    print("Template sections:")
    for sec in wiz.get("template_sections", []) or []:
        print(f"- {sec}")
    print("\nNext command:")
    print(wiz.get("next_command", ""))


def _slugify_text(raw: str) -> str:
    tokens = _tokenize_text(raw)
    return "_".join(tokens[:8]) if tokens else "incident"


def _incident_file_candidates() -> list[Path]:
    DEFAULT_INCIDENTS_DIR.mkdir(parents=True, exist_ok=True)
    return [p for p in sorted(DEFAULT_INCIDENTS_DIR.iterdir(), key=lambda x: x.stat().st_mtime, reverse=True) if p.is_file() and p.suffix.lower() == ".json"]


def _resolve_incident_file(incident_id: str) -> tuple[str, Path | None, list[str]]:
    wanted = (incident_id or "").strip()
    if not wanted:
        return "not_found", None, []
    files = _incident_file_candidates()
    exact = [p for p in files if p.stem == wanted or p.name == wanted]
    if len(exact) == 1:
        return "ok", exact[0], []
    if len(exact) > 1:
        return "ambiguous", None, [p.stem for p in exact]
    low = wanted.lower()
    partial = [p for p in files if low in p.stem.lower() or low in p.name.lower()]
    if len(partial) == 1:
        return "ok", partial[0], []
    if len(partial) > 1:
        return "ambiguous", None, [p.stem for p in partial]
    return "not_found", None, []


def _start_incident(title: str) -> tuple[str, dict]:
    clean_title = title.strip()
    if not clean_title:
        return "error", {"status": "error", "error": "informe titulo para --start-incident"}
    DEFAULT_INCIDENTS_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    incident_id = f"inc-{stamp}-{_slugify_text(clean_title)}"
    path = DEFAULT_INCIDENTS_DIR / f"{incident_id}.json"
    payload = {
        "incident_id": incident_id,
        "title": clean_title,
        "status": "open",
        "opened_at": datetime.now().isoformat(timespec="seconds"),
        "closed_at": "",
        "notes": [],
        "suggested_plan": "",
        "selected_plan": "",
    }
    path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return "ok", {"status": "ok", "incident_id": incident_id, "path": str(path)}


def _incident_note(incident_id: str, note_text: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_incident_file(incident_id)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "incident_id ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"incidente nao encontrado: {incident_id}"}
    text = note_text.strip()
    if not text:
        return "error", {"status": "error", "error": "informe texto para --incident-note"}
    try:
        data = json.loads(path.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        data = {}
    if not isinstance(data, dict):
        data = {}
    notes = data.get("notes", [])
    if not isinstance(notes, list):
        notes = []
    entry = {"ts": datetime.now().isoformat(timespec="seconds"), "text": text}
    notes.append(entry)
    data["notes"] = notes
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return "ok", {"status": "ok", "incident_id": data.get("incident_id", path.stem), "note": entry, "path": str(path)}


def _close_incident(incident_id: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_incident_file(incident_id)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "incident_id ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"incidente nao encontrado: {incident_id}"}
    try:
        data = json.loads(path.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        data = {}
    if not isinstance(data, dict):
        data = {}
    data["status"] = "closed"
    data["closed_at"] = datetime.now().isoformat(timespec="seconds")
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return "ok", {"status": "ok", "incident_id": data.get("incident_id", path.stem), "closed_at": data.get("closed_at", ""), "path": str(path)}


def _normalize_logged_command(command_raw: str) -> str:
    cmd = re.sub(r"\s+", " ", command_raw.strip())
    if not cmd:
        return cmd
    cmd = re.sub(r"(\s-n\s+)([^\s]+)", r"\1<namespace>", cmd)
    cmd = re.sub(r"(--namespace=)([^\s]+)", r"\1<namespace>", cmd)
    cmd = re.sub(r"(--namespace\s+)([^\s]+)", r"\1<namespace>", cmd)
    cmd = re.sub(r"(\brollout restart deployment\s+)([^\s]+)", r"\1<deployment>", cmd, flags=re.IGNORECASE)
    cmd = re.sub(r"(\b(get|describe)\s+deployment\s+)([^\s]+)", r"\1<deployment>", cmd, flags=re.IGNORECASE)
    cmd = re.sub(r"(\b(get|describe)\s+pod\s+)([^\s]+)", r"\1<pod>", cmd, flags=re.IGNORECASE)
    cmd = re.sub(r"(\blogs\s+)([^\s-][^\s]*)", r"\1<pod>", cmd, flags=re.IGNORECASE)
    return cmd


def _log_command_event(
    command_raw: str,
    *,
    incident_id: str = "",
    cluster: str = "",
    namespace: str = "",
    exit_code: int = 0,
    duration_ms: int = 0,
    plan_name: str = "",
) -> tuple[str, dict]:
    cmd = command_raw.strip()
    if not cmd:
        return "error", {"status": "error", "error": "informe comando para --log-command"}

    resolved_incident = ""
    if incident_id.strip():
        i_status, i_path, i_candidates = _resolve_incident_file(incident_id.strip())
        if i_status == "ambiguous":
            return "error", {"status": "error", "error": "incident_id ambiguo", "candidates": i_candidates}
        if i_status != "ok" or i_path is None:
            return "error", {"status": "error", "error": f"incidente nao encontrado: {incident_id}"}
        resolved_incident = i_path.stem

    resolved_plan = ""
    if plan_name.strip():
        p_status, p_path, p_candidates = _resolve_show_plan(plan_name.strip())
        if p_status == "ambiguous":
            return "error", {"status": "error", "error": "plano ambiguo", "candidates": p_candidates}
        if p_status != "ok" or p_path is None:
            return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}
        resolved_plan = p_path.name

    row = {
        "ts": datetime.now().isoformat(timespec="seconds"),
        "incident_id": resolved_incident,
        "cluster": cluster.strip(),
        "namespace": namespace.strip(),
        "plan_name": resolved_plan,
        "command_raw": cmd,
        "command_normalized": _normalize_logged_command(cmd),
        "exit_code": int(exit_code),
        "duration_ms": int(duration_ms),
    }
    COMMAND_EVENTS_PATH.parent.mkdir(parents=True, exist_ok=True)
    with COMMAND_EVENTS_PATH.open("a", encoding="utf-8") as f:
        f.write(json.dumps(row, ensure_ascii=False) + "\n")
    return "ok", {"status": "ok", "event": row, "events_path": str(COMMAND_EVENTS_PATH)}


def _read_command_events() -> list[dict]:
    if not COMMAND_EVENTS_PATH.exists():
        return []
    out: list[dict] = []
    for line in COMMAND_EVENTS_PATH.read_text(encoding="utf-8", errors="replace").splitlines():
        s = line.strip()
        if not s:
            continue
        try:
            obj = json.loads(s)
        except json.JSONDecodeError:
            continue
        if isinstance(obj, dict):
            out.append(obj)
    return out


def _load_incidents_rows() -> list[dict]:
    rows = []
    for path in _incident_file_candidates():
        try:
            data = json.loads(path.read_text(encoding="utf-8", errors="replace"))
        except Exception:
            continue
        if isinstance(data, dict):
            rows.append(data)
    return rows


def _learning_report_payload() -> dict:
    incidents = _load_incidents_rows()
    events = _read_command_events()
    cmd_counter: Counter = Counter()
    plan_counter: Counter = Counter()
    for ev in events:
        norm = str(ev.get("command_normalized", "") or "").strip()
        if norm:
            cmd_counter[norm] += 1
        plan = str(ev.get("plan_name", "") or "").strip()
        if plan:
            plan_counter[plan] += 1

    top_commands = [{"command": cmd, "count": int(cnt)} for cmd, cnt in cmd_counter.most_common(10)]
    top_plans = [{"plan": p, "count": int(c)} for p, c in plan_counter.most_common(10)]
    open_count = sum(1 for i in incidents if str(i.get("status", "") or "").lower() == "open")
    closed_count = sum(1 for i in incidents if str(i.get("status", "") or "").lower() == "closed")

    suggestions: list[str] = []
    if top_plans:
        for row in top_plans[:3]:
            if int(row.get("count", 0)) >= 2:
                suggestions.append(f"plano {row.get('plan', '')} foi usado varias vezes ({row.get('count', 0)} eventos)")
    if top_commands and top_plans:
        best_plan = str(top_plans[0].get("plan", "") or "")
        status, payload = _extract_commands_from_saved_plan(best_plan)
        plan_cmds = set()
        if status == "ok":
            plan_cmds = set(str(c).strip().lower() for c in (payload.get("commands", []) or []) if str(c).strip())
        for row in top_commands[:5]:
            c = str(row.get("command", "") or "").strip().lower()
            if c and c not in plan_cmds and int(row.get("count", 0)) >= 1:
                suggestions.append(f"comando recorrente ainda nao aparece em plano {best_plan}: {row.get('command', '')}")
                break

    return {
        "status": "ok",
        "top_commands": top_commands,
        "top_plans": top_plans,
        "incidents_summary": {"total": len(incidents), "open": open_count, "closed": closed_count},
        "suggestions": suggestions[:6],
    }


def _render_learning_report_text(payload: dict) -> None:
    print("Learning report:")
    print("Top comandos normalizados:")
    for row in payload.get("top_commands", []) or []:
        print(f"- {row.get('command', '')} | count={row.get('count', 0)}")
    if not (payload.get("top_commands", []) or []):
        print("- (sem eventos)")
    print("Top planos associados:")
    for row in payload.get("top_plans", []) or []:
        print(f"- {row.get('plan', '')} | count={row.get('count', 0)}")
    if not (payload.get("top_plans", []) or []):
        print("- (sem planos associados)")
    summary = payload.get("incidents_summary", {}) or {}
    print(f"Incidentes: total={summary.get('total', 0)} open={summary.get('open', 0)} closed={summary.get('closed', 0)}")
    print("Sugestoes:")
    for s in payload.get("suggestions", []) or []:
        print(f"- {s}")
    if not (payload.get("suggestions", []) or []):
        print("- (sem sugestoes)")


def _observed_plan_names() -> set[str]:
    names: set[str] = set()
    for p in _list_plans():
        name = str(p.get("name", "") or "").strip()
        if name:
            names.add(name)
    state = _load_usage_state()
    plans = state.get("plans", {})
    if isinstance(plans, dict):
        for name in plans.keys():
            clean = str(name or "").strip()
            if clean:
                names.add(clean)
    for row in _load_incidents_rows():
        suggested = str(row.get("suggested_plan", "") or "").strip()
        selected = str(row.get("selected_plan", "") or "").strip()
        if suggested:
            names.add(suggested)
        if selected:
            names.add(selected)
    for ev in _read_command_events():
        plan_name = str(ev.get("plan_name", "") or "").strip()
        if plan_name:
            names.add(plan_name)
    return names


def _plan_metrics_payload(plan_filter: str = "") -> dict:
    usage_state = _load_usage_state()
    usage_plans = usage_state.get("plans", {})
    if not isinstance(usage_plans, dict):
        usage_plans = {}
    incidents = _load_incidents_rows()
    events = _read_command_events()
    incidents_by_id: dict[str, dict] = {}
    for row in incidents:
        iid = str(row.get("incident_id", "") or "").strip()
        if iid:
            incidents_by_id[iid] = row

    all_names = _observed_plan_names()
    wanted = plan_filter.strip()
    if wanted and wanted != "__ALL__":
        all_names = {wanted}
    if not all_names:
        return {"status": "ok", "plans": []}

    stats: dict[str, dict] = {}
    for name in all_names:
        row = usage_plans.get(name, {})
        if not isinstance(row, dict):
            row = {}
        stats[name] = {
            "name": name,
            "suggest_count": int(row.get("suggest_count", 0) or 0),
            "selected_count": int(row.get("selected_count", 0) or 0),
            "open_count": int(row.get("open_count", 0) or 0),
            "command_count": 0,
            "_incident_ids": set(),
            "_closed_incident_ids": set(),
        }

    for inc in incidents:
        iid = str(inc.get("incident_id", "") or "").strip()
        if not iid:
            continue
        linked = set()
        suggested = str(inc.get("suggested_plan", "") or "").strip()
        selected = str(inc.get("selected_plan", "") or "").strip()
        if suggested:
            linked.add(suggested)
        if selected:
            linked.add(selected)
        is_closed = str(inc.get("status", "") or "").strip().lower() == "closed"
        for name in linked:
            if name not in stats:
                if wanted and wanted != "__ALL__":
                    continue
                stats[name] = {
                    "name": name,
                    "suggest_count": 0,
                    "selected_count": 0,
                    "open_count": 0,
                    "command_count": 0,
                    "_incident_ids": set(),
                    "_closed_incident_ids": set(),
                }
            stats[name]["_incident_ids"].add(iid)
            if is_closed:
                stats[name]["_closed_incident_ids"].add(iid)

    for ev in events:
        name = str(ev.get("plan_name", "") or "").strip()
        if not name:
            continue
        if name not in stats:
            if wanted and wanted != "__ALL__":
                continue
            stats[name] = {
                "name": name,
                "suggest_count": 0,
                "selected_count": 0,
                "open_count": 0,
                "command_count": 0,
                "_incident_ids": set(),
                "_closed_incident_ids": set(),
            }
        stats[name]["command_count"] += 1
        iid = str(ev.get("incident_id", "") or "").strip()
        if iid:
            stats[name]["_incident_ids"].add(iid)
            inc_row = incidents_by_id.get(iid, {})
            if str(inc_row.get("status", "") or "").strip().lower() == "closed":
                stats[name]["_closed_incident_ids"].add(iid)

    plans: list[dict] = []
    for name, row in stats.items():
        incident_count = len(row.get("_incident_ids", set()) or set())
        closed_count = len(row.get("_closed_incident_ids", set()) or set())
        success_rate = round(closed_count / max(incident_count, 1), 4)
        plans.append(
            {
                "name": name,
                "suggest_count": int(row.get("suggest_count", 0) or 0),
                "selected_count": int(row.get("selected_count", 0) or 0),
                "open_count": int(row.get("open_count", 0) or 0),
                "incident_count": int(incident_count),
                "closed_incident_count": int(closed_count),
                "command_count": int(row.get("command_count", 0) or 0),
                "success_rate": success_rate,
            }
        )

    plans.sort(
        key=lambda x: (
            float(x.get("success_rate", 0.0)),
            int(x.get("closed_incident_count", 0)),
            int(x.get("incident_count", 0)),
            int(x.get("command_count", 0)),
            str(x.get("name", "")),
        ),
        reverse=True,
    )
    return {"status": "ok", "plans": plans}


def _render_plan_metrics_text(payload: dict, plan_filter: str = "") -> None:
    rows = payload.get("plans", []) or []
    wanted = plan_filter.strip()
    if not rows:
        print("(sem metricas de plano)")
        return
    if wanted and wanted != "__ALL__":
        row = rows[0]
        print(f"Plan metrics: {row.get('name', '')}")
        print(f"- suggest_count: {row.get('suggest_count', 0)}")
        print(f"- selected_count: {row.get('selected_count', 0)}")
        print(f"- open_count: {row.get('open_count', 0)}")
        print(f"- incident_count: {row.get('incident_count', 0)}")
        print(f"- closed_incident_count: {row.get('closed_incident_count', 0)}")
        print(f"- command_count: {row.get('command_count', 0)}")
        print(f"- success_rate: {row.get('success_rate', 0.0):.4f}")
        return
    print("Plan metrics (ranking):")
    for row in rows[:20]:
        print(
            f"- {row.get('name', '')} | success={row.get('success_rate', 0.0):.4f} | incidents={row.get('incident_count', 0)} "
            f"| closed={row.get('closed_incident_count', 0)} | commands={row.get('command_count', 0)} "
            f"| suggest={row.get('suggest_count', 0)} | selected={row.get('selected_count', 0)} | open={row.get('open_count', 0)}"
        )


def _incident_type_for_event(ev: dict, incidents_by_id: dict[str, dict], plan_incident_type: dict[str, str]) -> str:
    plan_name = str(ev.get("plan_name", "") or "").strip()
    if plan_name:
        p_type = str(plan_incident_type.get(plan_name, "") or "").strip().lower()
        if p_type:
            return p_type

    iid = str(ev.get("incident_id", "") or "").strip()
    inc = incidents_by_id.get(iid, {}) if iid else {}
    if isinstance(inc, dict) and inc:
        selected = str(inc.get("selected_plan", "") or "").strip()
        suggested = str(inc.get("suggested_plan", "") or "").strip()
        for p_name in (selected, suggested):
            p_type = str(plan_incident_type.get(p_name, "") or "").strip().lower()
            if p_type:
                return p_type
        title = str(inc.get("title", "") or "").strip()
        if title:
            inferred = _infer_incident_type_from_query(title)
            if inferred:
                return inferred

    cmd = str(ev.get("command_normalized", "") or ev.get("command_raw", "") or "").strip()
    if cmd:
        return _infer_incident_type_from_query(cmd)
    return ""


def _command_metrics_payload(incident_type_filter: str = "") -> dict:
    events = _read_command_events()
    incidents = _load_incidents_rows()
    incidents_by_id: dict[str, dict] = {}
    for row in incidents:
        iid = str(row.get("incident_id", "") or "").strip()
        if iid:
            incidents_by_id[iid] = row

    plan_incident_type: dict[str, str] = {}
    for meta in _list_plans() + _list_archived_plans():
        name = str(meta.get("name", "") or "").strip()
        it = str(meta.get("incident_type", "") or "").strip().lower()
        if name and it:
            plan_incident_type[name] = it

    wanted = incident_type_filter.strip().lower()
    stats: dict[str, dict] = {}
    for ev in events:
        cmd = str(ev.get("command_normalized", "") or "").strip()
        if not cmd:
            raw = str(ev.get("command_raw", "") or "").strip()
            cmd = _normalize_logged_command(raw)
        if not cmd:
            continue

        event_incident_type = _incident_type_for_event(ev, incidents_by_id, plan_incident_type)
        if wanted and event_incident_type != wanted:
            continue

        row = stats.setdefault(
            cmd,
            {
                "command_normalized": cmd,
                "used_count": 0,
                "success_count": 0,
                "_duration_sum": 0.0,
                "_duration_count": 0,
                "_incident_ids": set(),
                "_incident_types": set(),
            },
        )
        row["used_count"] += 1
        exit_code = int(ev.get("exit_code", 0) or 0)
        if exit_code == 0:
            row["success_count"] += 1
        duration = int(ev.get("duration_ms", 0) or 0)
        if duration > 0:
            row["_duration_sum"] += float(duration)
            row["_duration_count"] += 1
        iid = str(ev.get("incident_id", "") or "").strip()
        if iid:
            row["_incident_ids"].add(iid)
        if event_incident_type:
            row["_incident_types"].add(event_incident_type)

    commands: list[dict] = []
    by_incident_type: dict[str, list[dict]] = {}
    for row in stats.values():
        duration_count = int(row.get("_duration_count", 0) or 0)
        avg = round(float(row.get("_duration_sum", 0.0)) / duration_count, 1) if duration_count > 0 else 0.0
        out = {
            "command_normalized": row.get("command_normalized", ""),
            "used_count": int(row.get("used_count", 0) or 0),
            "incident_count": int(len(row.get("_incident_ids", set()) or set())),
            "incident_types_seen": sorted(str(x) for x in (row.get("_incident_types", set()) or set()) if str(x).strip()),
            "avg_duration_ms": float(avg),
            "success_count": int(row.get("success_count", 0) or 0),
        }
        commands.append(out)
        for it in out.get("incident_types_seen", []) or []:
            by_incident_type.setdefault(it, []).append(out)

    commands.sort(
        key=lambda x: (
            int(x.get("used_count", 0)),
            int(x.get("success_count", 0)),
            int(x.get("incident_count", 0)),
            str(x.get("command_normalized", "")),
        ),
        reverse=True,
    )
    for it, rows in by_incident_type.items():
        rows.sort(
            key=lambda x: (
                int(x.get("used_count", 0)),
                int(x.get("success_count", 0)),
                int(x.get("incident_count", 0)),
                str(x.get("command_normalized", "")),
            ),
            reverse=True,
        )

    return {"status": "ok", "commands": commands, "by_incident_type": by_incident_type}


def _render_command_metrics_text(payload: dict, incident_type_filter: str = "") -> None:
    rows = payload.get("commands", []) or []
    if not rows:
        print("(sem metricas de comando)")
        return
    wanted = incident_type_filter.strip().lower()
    if wanted:
        print(f"Command metrics for incident_type={wanted}:")
    else:
        print("Top comandos por uso:")
    for row in rows[:15]:
        types = ",".join(row.get("incident_types_seen", []) or []) or "-"
        print(
            f"- {row.get('command_normalized', '')} | used={row.get('used_count', 0)} | success={row.get('success_count', 0)} "
            f"| incidents={row.get('incident_count', 0)} | types={types} | avg_ms={row.get('avg_duration_ms', 0.0):.1f}"
        )
    if wanted:
        return
    print("\nTop comandos por incident_type:")
    by_type = payload.get("by_incident_type", {}) or {}
    if not by_type:
        print("- (sem incident_type inferido)")
        return
    for it in sorted(by_type.keys()):
        top = by_type.get(it, [])[:3]
        if not top:
            continue
        print(f"- {it}:")
        for row in top:
            print(f"  * {row.get('command_normalized', '')} | used={row.get('used_count', 0)} | success={row.get('success_count', 0)}")


def _suggest_runbook_improvements_payload(plan_filter: str = "") -> dict:
    metrics_payload = _plan_metrics_payload(plan_filter=plan_filter)
    plan_metrics_rows = metrics_payload.get("plans", []) or []
    plan_metrics_map = {str(r.get("name", "") or ""): r for r in plan_metrics_rows}

    command_metrics = _command_metrics_payload()
    _ = command_metrics
    events = _read_command_events()
    incidents = _load_incidents_rows()
    incidents_by_id: dict[str, dict] = {}
    for row in incidents:
        iid = str(row.get("incident_id", "") or "").strip()
        if iid:
            incidents_by_id[iid] = row

    stale_names = _stale_plan_names_set()
    deprecated_names = set(str(p.get("name", "") or "").strip() for p in _list_deprecated_plans())
    metas = {str(p.get("name", "") or "").strip(): p for p in _list_plans()}

    target = plan_filter.strip()
    candidate_names = set(plan_metrics_map.keys()) | set(metas.keys())
    if target and target != "__ALL__":
        candidate_names = {target}

    suggestions: list[dict] = []
    for plan_name in sorted(name for name in candidate_names if name):
        metric = plan_metrics_map.get(
            plan_name,
            {
                "incident_count": 0,
                "closed_incident_count": 0,
                "command_count": 0,
                "suggest_count": 0,
                "selected_count": 0,
                "open_count": 0,
                "success_rate": 0.0,
            },
        )
        usage_total = (
            int(metric.get("suggest_count", 0))
            + int(metric.get("selected_count", 0))
            + int(metric.get("open_count", 0))
            + int(metric.get("command_count", 0))
        )
        ev_counter: Counter = Counter()
        for ev in events:
            linked = str(ev.get("plan_name", "") or "").strip()
            iid = str(ev.get("incident_id", "") or "").strip()
            if linked != plan_name and iid:
                inc = incidents_by_id.get(iid, {})
                selected = str(inc.get("selected_plan", "") or "").strip()
                suggested = str(inc.get("suggested_plan", "") or "").strip()
                if plan_name not in {selected, suggested}:
                    continue
            elif linked != plan_name:
                continue
            cmd = str(ev.get("command_normalized", "") or "").strip() or _normalize_logged_command(str(ev.get("command_raw", "") or ""))
            if cmd:
                ev_counter[cmd] += 1

        plan_cmds: set[str] = set()
        extract_status, extract_payload = _extract_commands_from_saved_plan(plan_name)
        if extract_status == "ok":
            plan_cmds = set(str(c).strip().lower() for c in (extract_payload.get("commands", []) or []) if str(c).strip())

        missing_candidates = []
        for cmd, cnt in ev_counter.most_common():
            if cnt < 2:
                continue
            if cmd.lower() in plan_cmds:
                continue
            missing_candidates.append((cmd, cnt))
        if missing_candidates:
            cmd, cnt = missing_candidates[0]
            suggestions.append(
                {
                    "plan": plan_name,
                    "type": "missing_command",
                    "reason": f"comando recorrente observado ({cnt}x) e ausente no plano",
                    "suggested_change": f"adicionar {cmd}",
                }
            )

        validate_status, validate_payload = _validate_plan(plan_name)
        if validate_status == "ok":
            missing = [str(x) for x in (validate_payload.get("missing", []) or []) if str(x).strip()]
            if missing and str(validate_payload.get("incident_type", "") or "").strip():
                suggestions.append(
                    {
                        "plan": plan_name,
                        "type": "incomplete_checklist",
                        "reason": f"plano com incident_type definido e secoes ausentes: {', '.join(missing[:4])}",
                        "suggested_change": "completar checklist minimo do template para este incident_type",
                    }
                )
            if usage_total >= 3 and ("validation" in missing or "commands_minimos" in missing):
                suggestions.append(
                    {
                        "plan": plan_name,
                        "type": "weak_validation",
                        "reason": f"plano muito usado ({usage_total} sinais) com validacao fraca",
                        "suggested_change": "fortalecer secao de validation e comandos de verificacao pos-acao",
                    }
                )

        if plan_name in stale_names and usage_total >= 3:
            suggestions.append(
                {
                    "plan": plan_name,
                    "type": "stale_high_use",
                    "reason": f"plano stale com uso observado alto ({usage_total} sinais)",
                    "suggested_change": "rodar refresh do plano e revisar comandos/validacao",
                }
            )

        if plan_name in deprecated_names and usage_total >= 2:
            suggestions.append(
                {
                    "plan": plan_name,
                    "type": "deprecated_still_used",
                    "reason": f"plano deprecated ainda com uso observado ({usage_total} sinais)",
                    "suggested_change": "migrar uso para plano ativo equivalente e atualizar vinculos operacionais",
                }
            )

        if int(metric.get("incident_count", 0) or 0) >= 2 and float(metric.get("success_rate", 0.0) or 0.0) < 0.5:
            suggestions.append(
                {
                    "plan": plan_name,
                    "type": "low_success_rate",
                    "reason": f"taxa de fechamento baixa ({metric.get('success_rate', 0.0):.4f}) para incidentes associados",
                    "suggested_change": "revisar sequencia de passos e adicionar validacoes intermediarias",
                }
            )

    return {"status": "ok", "suggestions": suggestions}


def _render_suggest_runbook_improvements_text(payload: dict) -> None:
    rows = payload.get("suggestions", []) or []
    if not rows:
        print("(sem sugestoes de melhoria)")
        return
    grouped: dict[str, list[dict]] = {}
    for row in rows:
        plan = str(row.get("plan", "") or "").strip() or "(sem plano)"
        grouped.setdefault(plan, []).append(row)
    print("Sugestoes de melhoria de runbook:")
    for plan in sorted(grouped.keys()):
        print(f"- {plan}")
        for row in grouped.get(plan, []):
            print(f"  * [{row.get('type', '')}] {row.get('reason', '')}")
            print(f"    sugestao: {row.get('suggested_change', '')}")


def _load_incident_json(path: Path) -> dict:
    try:
        data = json.loads(path.read_text(encoding="utf-8", errors="replace"))
    except Exception:
        data = {}
    return data if isinstance(data, dict) else {}


def _incident_link_plan(incident_id: str, plan_name: str, kind: str) -> tuple[str, dict]:
    i_status, i_path, i_candidates = _resolve_incident_file(incident_id)
    if i_status == "ambiguous":
        return "error", {"status": "error", "error": "incident_id ambiguo", "candidates": i_candidates}
    if i_status != "ok" or i_path is None:
        return "error", {"status": "error", "error": f"incidente nao encontrado: {incident_id}"}

    p_status, p_path, p_candidates = _resolve_show_plan(plan_name)
    if p_status == "ambiguous":
        return "error", {"status": "error", "error": "plano ambiguo", "candidates": p_candidates}
    if p_status != "ok" or p_path is None:
        return "error", {"status": "error", "error": f"plano nao encontrado: {plan_name}"}

    data = _load_incident_json(i_path)
    if kind == "suggested":
        data["suggested_plan"] = p_path.name
        data["suggested_plan_at"] = datetime.now().isoformat(timespec="seconds")
    else:
        data["selected_plan"] = p_path.name
        data["selected_plan_at"] = datetime.now().isoformat(timespec="seconds")
    i_path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return "ok", {"status": "ok", "incident_id": data.get("incident_id", i_path.stem), "plan_name": p_path.name, "kind": kind, "path": str(i_path)}


def _show_incident(incident_id: str) -> tuple[str, dict]:
    status, path, candidates = _resolve_incident_file(incident_id)
    if status == "ambiguous":
        return "error", {"status": "error", "error": "incident_id ambiguo", "candidates": candidates}
    if status != "ok" or path is None:
        return "error", {"status": "error", "error": f"incidente nao encontrado: {incident_id}"}
    data = _load_incident_json(path)
    return "ok", {"status": "ok", "incident": data}


def _render_show_incident_text(payload: dict) -> None:
    incident = payload.get("incident", {}) or {}
    print(f"Incident ID: {incident.get('incident_id', '')}")
    print(f"Title: {incident.get('title', '')}")
    print(f"Status: {incident.get('status', '')}")
    print(f"Opened At: {incident.get('opened_at', '')}")
    print(f"Closed At: {incident.get('closed_at', '')}")
    print(f"Suggested Plan: {incident.get('suggested_plan', '') or '(nenhum)'}")
    print(f"Selected Plan: {incident.get('selected_plan', '') or '(nenhum)'}")
    notes = incident.get("notes", []) or []
    print("Notes:")
    if not notes:
        print("- (sem notas)")
    for n in notes:
        print(f"- [{n.get('ts', '')}] {n.get('text', '')}")


def _incident_timeline_payload(incident_id: str) -> tuple[str, dict]:
    status, payload = _show_incident(incident_id)
    if status != "ok":
        return status, payload
    incident = payload.get("incident", {}) or {}
    iid = str(incident.get("incident_id", "") or "")
    timeline: list[dict] = []
    opened = str(incident.get("opened_at", "") or "").strip()
    if opened:
        timeline.append({"ts": opened, "type": "opened", "data": {"title": incident.get("title", "")}})
    for note in incident.get("notes", []) or []:
        ts = str(note.get("ts", "") or "").strip()
        timeline.append({"ts": ts, "type": "note", "data": {"text": note.get("text", "")}})
    if str(incident.get("suggested_plan", "") or "").strip():
        timeline.append(
            {
                "ts": str(incident.get("suggested_plan_at", "") or opened),
                "type": "suggested_plan",
                "data": {"plan_name": incident.get("suggested_plan", "")},
            }
        )
    if str(incident.get("selected_plan", "") or "").strip():
        timeline.append(
            {
                "ts": str(incident.get("selected_plan_at", "") or opened),
                "type": "selected_plan",
                "data": {"plan_name": incident.get("selected_plan", "")},
            }
        )
    for ev in _read_command_events():
        if str(ev.get("incident_id", "") or "").strip() == iid:
            timeline.append({"ts": str(ev.get("ts", "") or ""), "type": "command", "data": ev})
    closed = str(incident.get("closed_at", "") or "").strip()
    if closed:
        timeline.append({"ts": closed, "type": "closed", "data": {}})
    timeline.sort(key=lambda x: str(x.get("ts", "") or ""))
    return "ok", {"status": "ok", "incident_id": iid, "timeline": timeline}


def _render_incident_timeline_text(payload: dict) -> None:
    print(f"Incident Timeline: {payload.get('incident_id', '')}")
    rows = payload.get("timeline", []) or []
    if not rows:
        print("(timeline vazia)")
        return
    for row in rows:
        ts = row.get("ts", "")
        typ = row.get("type", "")
        data = row.get("data", {}) or {}
        if typ == "note":
            print(f"- {ts} | note | {data.get('text', '')}")
        elif typ in {"suggested_plan", "selected_plan"}:
            print(f"- {ts} | {typ} | {data.get('plan_name', '')}")
        elif typ == "command":
            print(f"- {ts} | command | {data.get('command_normalized', data.get('command_raw', ''))}")
        elif typ == "opened":
            print(f"- {ts} | opened | {data.get('title', '')}")
        else:
            print(f"- {ts} | {typ}")


def _incident_report(incident_id: str) -> tuple[str, dict]:
    s_status, s_payload = _show_incident(incident_id)
    if s_status != "ok":
        return s_status, s_payload
    t_status, t_payload = _incident_timeline_payload(incident_id)
    if t_status != "ok":
        return t_status, t_payload

    incident = s_payload.get("incident", {}) or {}
    timeline = t_payload.get("timeline", []) or []
    commands = [row for row in timeline if str(row.get("type", "")) == "command"]
    notes = incident.get("notes", []) or []
    observations = []
    observations.append(f"commands_observed={len(commands)}")
    observations.append(f"status={incident.get('status', '')}")
    if str(incident.get("selected_plan", "") or "").strip():
        observations.append(f"selected_plan={incident.get('selected_plan', '')}")
    if str(incident.get("status", "") or "").lower() != "closed":
        observations.append("incident_still_open")

    out_dir = DEFAULT_DOCS_DIR / "incidents"
    out_dir.mkdir(parents=True, exist_ok=True)
    iid = str(incident.get("incident_id", "") or "").strip()
    out_path = out_dir / f"incident_{iid}.md"
    lines = [
        "# Incident Report",
        "",
        "## Title",
        str(incident.get("title", "") or ""),
        "",
        "## Incident ID",
        iid,
        "",
        "## Status",
        str(incident.get("status", "") or ""),
        "",
        "## Opened At / Closed At",
        f"- opened_at: {incident.get('opened_at', '')}",
        f"- closed_at: {incident.get('closed_at', '')}",
        "",
        "## Suggested Plan",
        str(incident.get("suggested_plan", "") or "(none)"),
        "",
        "## Selected Plan",
        str(incident.get("selected_plan", "") or "(none)"),
        "",
        "## Notes",
    ]
    if notes:
        for n in notes:
            lines.append(f"- [{n.get('ts', '')}] {n.get('text', '')}")
    else:
        lines.append("- (sem notas)")
    lines.extend(["", "## Commands Observed"])
    if commands:
        for c in commands:
            data = c.get("data", {}) or {}
            lines.append(f"- [{c.get('ts', '')}] {data.get('command_normalized', data.get('command_raw', ''))}")
    else:
        lines.append("- (sem comandos)")
    lines.extend(["", "## Timeline"])
    for row in timeline:
        lines.append(f"- {row.get('ts', '')} | {row.get('type', '')}")
    lines.extend(["", "## Observations"])
    for obs in observations:
        lines.append(f"- {obs}")
    out_path.write_text("\n".join(lines).rstrip() + "\n", encoding="utf-8")
    return "ok", {"status": "ok", "incident_id": iid, "report_path": str(out_path)}

def main() -> int:
    parser = argparse.ArgumentParser(description="CLI inicial de copiloto Kubernetes (somente sugestoes, sem execucao).")
    parser.add_argument("--base-url", default=DEFAULT_BASE_URL, help=f"API base URL (default: {DEFAULT_BASE_URL})")
    parser.add_argument("--limit", type=int, default=5, help="limite de resultados semanticos")
    parser.add_argument(
        "--mode",
        choices=["default", "explain", "commands", "sources", "diagnose", "plan", "runbook"],
        default="default",
        help="modo de saida",
    )
    parser.add_argument(
        "--output",
        choices=["text", "json"],
        default="text",
        help="formato da saida",
    )
    parser.add_argument(
        "--format",
        choices=["compact", "full"],
        default="full",
        help="nivel de detalhamento da saida",
    )
    parser.add_argument("--pod", help="nome do pod alvo (substitui <pod>)")
    parser.add_argument("--container", help="nome do container alvo (substitui <container>)")
    parser.add_argument("--namespace", help="namespace alvo para comandos namespaced")
    parser.add_argument("--cluster", help="cluster alvo para contexto operacional")
    parser.add_argument("--environment", help="ambiente alvo (dev|staging|prod|local)")
    parser.add_argument("--deployment", help="nome do deployment alvo (substitui <nome> em comandos de deployment)")
    parser.add_argument("--save-plan", help="salva a saida atual em arquivo; nome simples vai para var/plans/")
    parser.add_argument("--list-plans", action="store_true", help="lista planos salvos em var/plans")
    parser.add_argument("--archive-plan", default="", help="arquiva plano ativo em var/archive/plans")
    parser.add_argument("--list-archived", action="store_true", help="lista planos arquivados em var/archive/plans")
    parser.add_argument("--restore-plan", default="", help="restaura plano arquivado para var/plans")
    parser.add_argument("--deprecate-plan", default="", help="marca plano ativo como deprecated")
    parser.add_argument("--undeprecate-plan", default="", help="remove marcacao deprecated de plano ativo")
    parser.add_argument("--list-deprecated", action="store_true", help="lista planos ativos marcados como deprecated")
    parser.add_argument("--set-context", default="", help="define contexto operacional de plano")
    parser.add_argument("--show-context", default="", help="mostra contexto operacional de plano")
    parser.add_argument("--set-incident-type", default="", help="define tipo de incidente para um plano")
    parser.add_argument("--incident-type", default="", help="tipo de incidente (set/filtro): debug|rollout|namespace|auth|networking|storage|observability|generic")
    parser.add_argument("--list-by-incident-type", action="store_true", help="lista planos agrupados por tipo de incidente")
    parser.add_argument("--intent", default="", help="filtro textual por intencao para listagem de planos")
    parser.add_argument("--search", default="", help="busca textual livre na biblioteca de planos salvos")
    parser.add_argument("--show-plan", default="", help="abre plano salvo por nome (exato ou match parcial unico)")
    parser.add_argument("--copy-plan", default="", help="copia um plano salvo para novo arquivo")
    parser.add_argument("--to", default="", help="destino para --copy-plan")
    parser.add_argument("--rename-plan", default="", help="renomeia um plano salvo para novo nome/caminho")
    parser.add_argument("--build-catalog", action="store_true", help="gera catalogo json/md dos planos")
    parser.add_argument("--build-ops-index", action="store_true", help="gera indice operacional por intent e tag")
    parser.add_argument("--build-templates", action="store_true", help="gera templates por incident_type em var/templates")
    parser.add_argument("--new-plan-from-template", default="", help="cria plano novo a partir de template de incident_type")
    parser.add_argument("--name", default="", help="nome do arquivo de plano para criacao por template")
    parser.add_argument("--goal", default="", help="goal opcional para criacao por template")
    parser.add_argument("--title", default="", help="title opcional para criacao por template")
    parser.add_argument("--validate-plan", default="", help="valida checklist minimo do plano por incident_type")
    parser.add_argument("--export-plan", default="", help="exporta um plano salvo para markdown em var/docs")
