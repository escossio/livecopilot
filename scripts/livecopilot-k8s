    parser.add_argument("--suggest-plan", default="", help="sugere planos locais por texto livre")
    parser.add_argument("--open-suggested-plan", default="", help="abre automaticamente o melhor plano sugerido")
    parser.add_argument("--explain-suggestion", default="", help="explica decisao de sugestao entre planos")
    parser.add_argument("--show-top-plans", action="store_true", help="mostra ranking local por favorito/uso")
    parser.add_argument("--show-usage", nargs="?", const="__ALL__", default="", help="mostra historico de uso (geral ou por plano)")
    parser.add_argument("--list-history", action="store_true", help="lista historico de versoes em var/history/plans")
    parser.add_argument("--show-history", default="", help="mostra historico de um plano especifico")
    parser.add_argument("--daily-plan", action="store_true", help="recomenda plano do dia com base em favoritos/uso local")
    parser.add_argument("--stale-plans", action="store_true", help="lista planos muito usados e sem refresh recente")
    parser.add_argument("--start-incident", default="", help="abre incidente operacional")
    parser.add_argument("--incident-note", nargs=2, metavar=("INCIDENT_ID", "TEXT"), help="adiciona nota em incidente")
    parser.add_argument("--close-incident", default="", help="fecha incidente operacional")
    parser.add_argument("--incident-suggest-plan", nargs=2, metavar=("INCIDENT_ID", "PLAN_NAME"), help="vincula plano sugerido ao incidente")
    parser.add_argument("--incident-select-plan", nargs=2, metavar=("INCIDENT_ID", "PLAN_NAME"), help="vincula plano selecionado ao incidente")
    parser.add_argument("--show-incident", default="", help="mostra incidente")
    parser.add_argument("--incident-timeline", default="", help="mostra timeline consolidada do incidente")
    parser.add_argument("--incident-report", default="", help="gera incident report em markdown")
    parser.add_argument("--log-command", default="", help="registra comando executado manualmente como evento")
    parser.add_argument("--incident-id", default="", help="incident id para --log-command")
    parser.add_argument("--exit-code", type=int, default=0, help="exit code observado para --log-command")
    parser.add_argument("--duration-ms", type=int, default=0, help="duracao em ms observada para --log-command")
    parser.add_argument("--plan", default="", help="plano associado para --log-command")
    parser.add_argument("--learning-report", action="store_true", help="gera relatorio simples de aprendizado local")
    parser.add_argument("--plan-metrics", nargs="?", const="__ALL__", default="", help="metricas de efetividade por plano (opcional: nome do plano)")
    parser.add_argument("--command-metrics", action="store_true", help="metricas de efetividade por comando normalizado")
    parser.add_argument(
        "--suggest-runbook-improvements",
        nargs="?",
        const="__ALL__",
        default="",
        help="sugere melhorias de runbook com base em historico local (opcional: nome do plano)",
    )
    parser.add_argument("--refresh-plan", default="", help="gera sugestao de refresh para plano stale")
    parser.add_argument("--save-refresh", default="", help="salva sugestao de refresh (nome simples vai para var/merge)")
    parser.add_argument("--suggest-upgrade", action="store_true", help="sugere upgrade para planos deprecated")
    parser.add_argument("--wizard-plan", default="", help="wizard para criar plano quando query for fraca")
    parser.add_argument("--find-duplicates", action="store_true", help="detecta planos potencialmente duplicados")
    parser.add_argument("--merge-plans", default="", help="gera merge assistido entre dois planos")
    parser.add_argument("--diff-plans", default="", help="compara dois planos por diff textual")
    parser.add_argument("--with", dest="with_plan", default="", help="segundo plano para diff")
    parser.add_argument("--save-diff", default="", help="salva diff em arquivo (nome simples vai para var/diffs)")
    parser.add_argument("--save-merge", default="", help="salva merge assistido (nome simples vai para var/merge)")
    parser.add_argument("--extract-commands", default="", help="extrai apenas comandos de um plano salvo")
    parser.add_argument("--tags", default="", help="tags para salvar plano, separadas por virgula")
    parser.add_argument("--tag", default="", help="filtro por tag na listagem/busca de planos")
    parser.add_argument("--versioned-save", action="store_true", help="ao substituir destino, salva versao anterior em var/history/plans")
    parser.add_argument("query", nargs="*", help="pergunta em texto livre")
    args = parser.parse_args()

    if args.show_top_plans:
        payload = _build_top_plans_usage()
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            _render_top_plans_text(payload)
        return 0

    if args.show_usage:
        result_status, payload = _show_usage(args.show_usage)
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                _render_usage_text(payload)
            else:
                print(f"ERRO: {payload.get('error', 'falha ao mostrar uso')}")
                for c in payload.get("candidates", []) or []:
                    print(f"- {c}")
