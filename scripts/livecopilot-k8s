def _post_json(base_url: str, path: str, payload: dict) -> dict:
    url = base_url.rstrip("/") + path
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(url, data=data, method="POST")
    req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = resp.read().decode("utf-8")
            return json.loads(body)
    except urllib.error.HTTPError as exc:
        raw = exc.read().decode("utf-8", errors="replace")
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return {"status": "error", "error": raw or f"http {exc.code}"}
    except Exception as exc:
        return {"status": "error", "error": str(exc)}


def _infer_intent(query: str) -> tuple[str, str]:
    q = query.lower()
    if "crashloop" in q or "--previous" in q or "previous" in q or "logs" in q:
        return ("Debug de pod/container", "Coletar logs atuais e anteriores, depois validar eventos e reinícios.")
    if "events" in q or "eventos" in q or "describe pod" in q:
        return ("Diagnóstico por eventos de pod", "Inspecionar eventos recentes e mensagens de erro para achar causa raiz.")
    if "rollout restart" in q or "restart deployment" in q:
        return ("Restart de deployment", "Aplicar restart controlado e acompanhar status do rollout.")
    if "create namespace" in q or "namespace" in q:
        return ("Gestão de namespace", "Criar namespace e confirmar existência antes de usar em outros comandos.")
    if "create token" in q or "serviceaccount" in q or "token" in q:
        return ("ServiceAccount e token", "Gerar token de ServiceAccount e validar escopo/namespace.")
    return ("Troubleshooting Kubernetes", "Coletar sinais operacionais com kubectl e executar diagnóstico incremental.")


def _extract_commands(text: str) -> list[str]:
    cmds: list[str] = []
    if not text:
        return cmds

    for m in re.findall(r"`(kubectl[^`\\n]+)`", text, flags=re.IGNORECASE):
        cmds.append(m.strip())
    for m in re.findall(r"`(k\\s+[^`\\n]+)`", text, flags=re.IGNORECASE):
        cmds.append(m.strip())
    for line in text.splitlines():
        s = line.strip()
        if s.lower().startswith("kubectl ") or s.lower().startswith("k "):
            cmds.append(s)

    normalized: list[str] = []
    seen = set()
    for cmd in cmds:
        cleaned = re.sub(r"\\s+", " ", cmd).strip().rstrip(".;")
        if cleaned.lower().startswith("k "):
            cleaned = "kubectl " + cleaned[2:].strip()
        key = cleaned.lower()
        if key and key not in seen:
            seen.add(key)
            normalized.append(cleaned)
    return normalized


def _fallback_commands(query: str) -> list[str]:
    q = query.lower()
    if "create token" in q or "serviceaccount" in q:
        return ["kubectl create sa myuser", "kubectl create token myuser", "kubectl -n default create token myuser"]
    if "create namespace" in q or "namespace" in q:
        return ["kubectl create namespace staging", "kubectl get namespace staging"]
    if "rollout restart" in q or "restart deployment" in q:
        return [
            "kubectl get deployment <nome>",
            "kubectl rollout restart deployment <nome>",
            "kubectl rollout status deployment <nome>",
        ]
    if "events" in q or "eventos" in q:
        return ["kubectl get events --sort-by=.lastTimestamp", "kubectl describe pod <pod>"]
    if "logs" in q or "crashloop" in q:
        return [
            "kubectl logs <pod> --previous",
            "kubectl logs <pod> -c <container> --previous",
            "kubectl describe pod <pod>",
            "kubectl get events --sort-by=.lastTimestamp",
        ]
    return ["kubectl get pods -A", "kubectl describe pod <pod>"]


def _translate_input_query(query: str) -> tuple[str, str | None]:
    s = re.sub(r"\s+", " ", query.strip())
    if not s:
        return s, None

    parts = s.split(" ")
    lower_parts = [p.lower() for p in parts]

    # Subcomandos ergonomicos.
    if len(lower_parts) == 2 and lower_parts[0] == "pod" and lower_parts[1] == "crashloop":
        return "pod em crashloopbackoff", "subcommand"
    if len(lower_parts) == 2 and lower_parts[0] == "pod" and lower_parts[1] == "events":
        return "ver eventos do pod", "subcommand"
    if len(lower_parts) >= 3 and lower_parts[0] == "deployment" and lower_parts[1] == "restart":
        deploy_name = " ".join(parts[2:]).strip()
        if deploy_name:
            return f"restart deployment {deploy_name}", "subcommand"
    if len(lower_parts) >= 3 and lower_parts[0] == "namespace" and lower_parts[1] == "create":
        ns_name = " ".join(parts[2:]).strip()
        if ns_name:
            return f"criar namespace {ns_name}", "subcommand"

    # Aliases anteriores.
    if len(lower_parts) == 1 and lower_parts[0] == "crashloop":
        return "pod em crashloopbackoff", None
    if len(lower_parts) == 1 and lower_parts[0] == "events":
        return "ver eventos do pod", None
    if len(lower_parts) >= 2 and lower_parts[0] == "ns":
        ns_name = " ".join(parts[1:]).strip()
        if ns_name:
            return f"criar namespace {ns_name}", None
    if len(lower_parts) >= 3 and lower_parts[0] == "restart" and lower_parts[1] == "deployment":
        deploy_name = " ".join(parts[2:]).strip()
        if deploy_name:
            return f"rollout restart deployment {deploy_name}", None

    return s, None


def _should_prefix_namespace(cmd: str) -> bool:
    c = cmd.strip().lower()
    if not c.startswith("kubectl "):
        return False
    if " -n " in c or c.startswith("kubectl -n ") or "--namespace" in c:
        return False
    if " -a " in c or " -a" in c or " -A " in cmd or "--all-namespaces" in c:
        return False
    namespace_global_ops = [
        "create namespace",
        "get namespace",
        "delete namespace",
        "get ns",
        "delete ns",
    ]
    for marker in namespace_global_ops:
        if marker in c:
            return False
    return True


def _resolve_commands_with_targets(
    commands: list[str],
    *,
    pod: str | None,
    container: str | None,
    namespace: str | None,
    deployment: str | None,
) -> list[str]:
    rendered: list[str] = []
    for raw in commands:
        cmd = raw
        if pod:
            cmd = cmd.replace("<pod>", pod)
        if container:
            cmd = cmd.replace("<container>", container)
        if deployment and "<nome>" in cmd and re.search(r"\bdeployment\b", cmd, flags=re.IGNORECASE):
            cmd = cmd.replace("<nome>", deployment)
        if namespace and _should_prefix_namespace(cmd):
            cmd = re.sub(r"^\s*kubectl\s+", f"kubectl -n {namespace} ", cmd, count=1, flags=re.IGNORECASE)
        rendered.append(cmd)
    return rendered


def _render_default(query: str, intent: str, explanation: str, commands: list[str], results: list[dict], format_style: str) -> None:
    if format_style == "compact":
        print(f"{intent}: {explanation}")
        for cmd in commands[:3]:
            print(cmd)
        return

    print("LiveCopilot K8s (preview)")
    print("nao executa comandos no cluster; apenas sugere.")
    print(f"\nIntencao: {intent}")
    print(f"Pergunta: {query}")
    print(f"\nExplicacao curta: {explanation}")
    print("\nComandos kubectl sugeridos:")
    for i, cmd in enumerate(commands[:8], start=1):
        print(f"{i}. {cmd}")

    print("\nFontes/contexto usados:")
    if not results:
        print("- (nenhum resultado semantico)")
    else:
        for item in results[:3]:
            similarity = item.get("similarity")
            source = item.get("source_file", "")
            title = str(item.get("title", "") or "").strip()
            if len(title) > 100:
                title = title[:100] + "..."
            print(f"- sim={similarity} | source={source} | title={title}")


