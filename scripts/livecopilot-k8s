        if not args.with_plan.strip():
            payload = {"status": "error", "error": "informe --with para merge de planos."}
            if args.output == "json":
                print(json.dumps(payload, ensure_ascii=False))
            else:
                print("ERRO: informe --with para merge de planos.")
            return 1
        result_status, payload = _merge_plans(args.merge_plans.strip(), args.with_plan.strip(), save_merge=args.save_merge.strip())
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                _render_merge_text(payload)
            else:
                print(f"ERRO: {payload.get('error', 'falha ao gerar merge')}")
                for c in payload.get("candidates", []) or []:
                    print(f"- {c}")
        return 0 if result_status == "ok" else 1

    if args.diff_plans:
        if not args.with_plan.strip():
            payload = {"status": "error", "error": "informe --with para comparar planos."}
            if args.output == "json":
                print(json.dumps(payload, ensure_ascii=False))
            else:
                print("ERRO: informe --with para comparar planos.")
            return 1
        result_status, payload = _diff_plans(args.diff_plans.strip(), args.with_plan.strip(), save_diff=args.save_diff.strip())
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                _render_diff_text(payload)
            else:
                print(f"ERRO: {payload.get('error', 'falha ao gerar diff')}")
                for c in payload.get("candidates", []) or []:
                    print(f"- {c}")
        return 0 if result_status == "ok" else 1

    if args.rename_plan:
        if not args.to.strip():
            if args.output == "json":
                print(json.dumps({"status": "error", "error": "informe --to para renomear plano."}, ensure_ascii=False))
            else:
                print("ERRO: informe --to para renomear plano.")
            return 1
        result_status, payload = _rename_plan(args.rename_plan.strip(), args.to.strip(), versioned_save=args.versioned_save)
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                print("Plano renomeado com sucesso.")
                print(f"Origem: {payload.get('renamed_from', '')}")
                print(f"Destino: {payload.get('renamed_to', '')}")
                print(f"Tamanho: {payload.get('size', 0)}")
                print(f"Tipo: {payload.get('content_type', '')}")
                if payload.get("versioned_backup"):
                    vb = payload.get("versioned_backup", {}) or {}
                    print(f"Backup versionado: {vb.get('path', '')} (size={vb.get('size', 0)})")
            else:
                err = str(payload.get("error", "falha ao renomear plano"))
                print(f"ERRO: {err}")
                candidates = payload.get("candidates", [])
                if isinstance(candidates, list) and candidates:
                    print("candidatos:")
                    for name in candidates:
                        print(f"- {name}")
        return 0 if result_status == "ok" else 1

    if args.build_catalog:
        payload = _build_catalog()
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            print("Catalogo gerado.")
            print(f"Diretorio: {payload.get('catalog_dir', '')}")
            print(f"JSON: {payload.get('catalog_json', '')}")
            print(f"Markdown: {payload.get('catalog_md', '')}")
            print(f"Planos: {payload.get('plans_count', 0)}")
        return 0

    if args.build_ops_index:
        payload = _build_ops_index()
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            print("Indice operacional gerado.")
            print(f"Diretorio: {payload.get('catalog_dir', '')}")
            print(f"JSON: {payload.get('ops_index_json', '')}")
            print(f"Markdown: {payload.get('ops_index_md', '')}")
            print(f"Intents: {payload.get('intents', 0)} | Tags: {payload.get('tags', 0)}")
        return 0

    if args.build_templates:
        payload = _build_templates()
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            print("Templates gerados.")
            print(f"Diretorio: {payload.get('templates_dir', '')}")
            print(f"Catalogo: {payload.get('catalog_md', '')}")
            print(f"Arquivos: {len(payload.get('templates', []) or [])}")
        return 0

    if args.new_plan_from_template:
        result_status, payload = _new_plan_from_template(
            args.new_plan_from_template.strip(),
            args.name.strip(),
            goal=args.goal,
            title=args.title,
            tags=args.tags,
            cluster=args.cluster or "",
            namespace=args.namespace or "",
            environment=args.environment or "",
        )
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                print(f"Plano criado: {payload.get('created_plan', '')}")
                print(f"Template: {payload.get('template_used', '')}")
                print(f"Path: {payload.get('path', '')}")
            else:
                print(f"ERRO: {payload.get('error', 'falha ao criar plano por template')}")
                allowed = payload.get("allowed", []) or []
                if allowed:
                    print(f"tipos aceitos: {', '.join(str(a) for a in allowed)}")
                if payload.get("hint"):
                    print(f"dica: {payload.get('hint', '')}")
        return 0 if result_status == "ok" else 1

    if args.validate_plan:
        result_status, payload = _validate_plan(args.validate_plan.strip())
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                _render_validate_plan_text(payload)
            else:
                print(f"ERRO: {payload.get('error', 'falha ao validar plano')}")
                for c in payload.get("candidates", []) or []:
                    print(f"- {c}")
        return 0 if result_status == "ok" else 1

    if args.export_plan:
        result_status, payload = _export_plan_to_markdown(args.export_plan.strip())
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                print("Plano exportado com sucesso.")
                print(f"Origem: {payload.get('source_plan', '')}")
                print(f"Markdown: {payload.get('exported_to', '')}")
                print(f"Comandos: {payload.get('commands_count', 0)}")
            else:
                err = str(payload.get("error", "falha ao exportar plano"))
                print(f"ERRO: {err}")
                candidates = payload.get("candidates", [])
                if isinstance(candidates, list) and candidates:
                    print("candidatos:")
                    for name in candidates:
                        print(f"- {name}")
        return 0 if result_status == "ok" else 1

    if args.copy_plan:
        if not args.to.strip():
            if args.output == "json":
                print(json.dumps({"status": "error", "error": "informe --to para copiar plano."}, ensure_ascii=False))
            else:
                print("ERRO: informe --to para copiar plano.")
            return 1
        result_status, payload = _copy_plan(args.copy_plan, args.to.strip(), versioned_save=args.versioned_save)
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                print("Plano copiado com sucesso.")
                print(f"Origem: {payload.get('copied_from', '')}")
                print(f"Destino: {payload.get('copied_to', '')}")
                print(f"Tipo: {payload.get('content_type', '')}")
                print(f"Tamanho: {payload.get('size', 0)}")
                if payload.get("versioned_backup"):
                    vb = payload.get("versioned_backup", {}) or {}
                    print(f"Backup versionado: {vb.get('path', '')} (size={vb.get('size', 0)})")
                if payload.get("tags"):
                    print(f"Tags: {','.join(str(t) for t in payload.get('tags', []))}")
            else:
                err = str(payload.get("error", "falha ao copiar plano"))
                print(f"ERRO: {err}")
                candidates = payload.get("candidates", [])
                if isinstance(candidates, list) and candidates:
                    print("candidatos:")
                    for name in candidates:
                        print(f"- {name}")
        return 0 if result_status == "ok" else 1

    if args.extract_commands:
        result_status, payload = _extract_commands_from_saved_plan(args.extract_commands.strip())
        if args.output == "json":
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if result_status == "ok":
                for cmd in payload.get("commands", []):
                    print(cmd)
            else:
                err = str(payload.get("error", "falha ao extrair comandos"))
                print(f"ERRO: {err}")
                candidates = payload.get("candidates", [])
                if isinstance(candidates, list) and candidates:
                    print("candidatos:")
                    for name in candidates:
                        print(f"- {name}")
        return 0 if result_status == "ok" else 1

    if args.show_plan:
        status, path, candidates = _resolve_show_plan(args.show_plan)
        if status == "ok" and path is not None:
            plan_data = _load_show_plan(path)
            _record_plan_usage(path.name, str(path), "open")
            if args.output == "json":
                print(json.dumps({"status": "ok", "plan": plan_data}, ensure_ascii=False))
            else:
                _render_show_plan_text(plan_data)
            return 0
        if status == "ambiguous":
            if args.output == "json":
                print(json.dumps({"status": "error", "error": "nome ambiguo", "candidates": candidates}, ensure_ascii=False))
            else:
                print("ERRO: nome ambiguo. candidatos:")
                for name in candidates:
                    print(f"- {name}")
            return 1
        if args.output == "json":
            print(json.dumps({"status": "error", "error": f"plano nao encontrado: {args.show_plan}"}, ensure_ascii=False))
        else:
            print(f"ERRO: plano nao encontrado: {args.show_plan}")
        return 1

    if args.list_plans or args.search or args.intent or args.tag or args.incident_type:
        plans = _list_plans(
            intent_filter=args.intent.strip(),
            search_filter=args.search.strip(),
            tag_filter=args.tag.strip(),
            incident_type_filter=args.incident_type.strip(),
        )
        if args.output == "json":
            print(
                json.dumps(
                    {
                        "status": "ok",
                        "plans_dir": str(DEFAULT_PLANS_DIR),
                        "intent_filter": args.intent.strip(),
                        "search_filter": args.search.strip(),
                        "tag_filter": args.tag.strip(),
                        "incident_type_filter": args.incident_type.strip(),
                        "plans": plans,
                    },
                    ensure_ascii=False,
                )
            )
        else:
            _render_list_plans_text(plans)
        return 0

    query = " ".join(args.query).strip()
    if not query:
        try:
            query = input("Pergunta Kubernetes: ").strip()
        except EOFError:
            query = ""
    if not query:
        if args.output == "json":
            print(json.dumps({"status": "error", "error": "informe uma pergunta."}, ensure_ascii=False))
        else:
            print("ERRO: informe uma pergunta.")
        return 1

    query, input_mode = _translate_input_query(query)

    payload = {"query": query, "limit": args.limit, "return_context": True}
    data = _post_json(args.base_url, "/semantic/search", payload)
    if data.get("status") != "ok":
        error_msg = str(data.get("error", "falha na busca semantica"))
        if args.output == "json":
            print(json.dumps({"status": "error", "error": error_msg}, ensure_ascii=False))
        else:
            print(f"ERRO: {error_msg}")
        return 1

    intent, explanation = _infer_intent(query)
    results = data.get("results") or []
    context = str(data.get("context", "") or "")
    combined_text = context + "\n" + "\n".join(str(item.get("snippet", "") or "") for item in results)
    extracted = _extract_commands(combined_text)
    seeded = _fallback_commands(query)
    commands = []
    seen_cmds = set()
    for cmd in seeded + extracted:
        key = cmd.strip().lower()
        if key and key not in seen_cmds:
            seen_cmds.add(key)
            commands.append(cmd)
    commands = _resolve_commands_with_targets(
        commands,
        pod=args.pod,
        container=args.container,
        namespace=args.namespace,
        deployment=args.deployment,
    )
    targets = {}
    if args.pod:
        targets["pod"] = args.pod
    if args.container:
        targets["container"] = args.container
    if args.namespace:
        targets["namespace"] = args.namespace
    if args.deployment:
        targets["deployment"] = args.deployment

    final_output = ""
    if args.output == "json":
        payload = _json_ok_payload(
            mode=args.mode,
            format_style=args.format,
            query=query,
            intent=intent,
            explanation=explanation,
            commands=commands,
            results=results,
            context=context,
            targets=targets,
            input_mode=input_mode,
        )
        final_output = json.dumps(payload, ensure_ascii=False)
    elif args.mode == "explain":
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_explain(query=query, intent=intent, explanation=explanation, format_style=args.format)
        final_output = buf.getvalue().rstrip()
    elif args.mode == "commands":
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_commands(query=query, commands=commands, format_style=args.format)
        final_output = buf.getvalue().rstrip()
    elif args.mode == "sources":
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_sources(query=query, context=context, results=results, format_style=args.format)
        final_output = buf.getvalue().rstrip()
    elif args.mode == "diagnose":
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_diagnose(
                query=query, intent=intent, explanation=explanation, commands=commands, results=results, format_style=args.format
            )
        final_output = buf.getvalue().rstrip()
    elif args.mode == "plan":
        goal = _build_plan_goal(intent=intent, explanation=explanation)
        plan_steps = _build_plan_steps(intent=intent, commands=commands)
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_plan(query=query, intent=intent, goal=goal, plan_steps=plan_steps, format_style=args.format)
        final_output = buf.getvalue().rstrip()
    elif args.mode == "runbook":
        goal = _build_plan_goal(intent=intent, explanation=explanation)
        title = _build_runbook_title(intent=intent)
        prechecks, recommended, validation, notes = _build_runbook_sections(intent=intent, commands=commands)
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_runbook(
                query=query,
                intent=intent,
                title=title,
                goal=goal,
                prechecks=prechecks,
                commands=recommended,
                validation=validation,
                notes=notes,
                format_style=args.format,
            )
        final_output = buf.getvalue().rstrip()
    else:
        buf = io.StringIO()
        with contextlib.redirect_stdout(buf):
            _render_default(
                query=query, intent=intent, explanation=explanation, commands=commands, results=results, format_style=args.format
            )
        final_output = buf.getvalue().rstrip()

    print(final_output)

    if args.save_plan:
        target_path = _resolve_plan_path(args.save_plan)
        tags = _parse_tags(args.tags)
        tagged_output = _inject_tags_into_saved_plan(final_output, tags)
        content = tagged_output + ("\n" if tagged_output and not tagged_output.endswith("\n") else "")
        versioned = None
        if target_path.exists() and args.versioned_save:
            versioned = _version_existing_destination(target_path)
        elif target_path.exists():
            if args.output == "json":
                print(json.dumps({"status": "error", "error": f"destino ja existe: {target_path}"}, ensure_ascii=False))
            else:
                print(f"ERRO: destino ja existe: {target_path} (use --versioned-save para versionar)")
            return 1
        target_path.write_text(content, encoding="utf-8")
        if args.output == "json":
            payload = {
                "status": "ok",
                "saved_to": str(target_path),
                "size": int(target_path.stat().st_size),
            }
            if versioned:
                payload["versioned_backup"] = versioned
            print(json.dumps(payload, ensure_ascii=False))
        else:
            if versioned:
                print(f"Plano salvo com versionamento: {target_path}")
                print(f"Backup versionado: {versioned.get('path', '')} (size={versioned.get('size', 0)})")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
