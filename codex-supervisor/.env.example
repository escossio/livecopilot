# OpenAI API key para execução real com Agents SDK
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Caminho absoluto do projeto-alvo (separado deste repositório)
TARGET_PROJECT_PATH=/lab/projects/target-project

# Default para POST /run-once quando target_project_path não for enviado
SUPERVISOR_DEFAULT_TARGET_PROJECT_PATH=/lab/projects/livecopilot

# Diretório base do supervisor (normalmente este repositório)
SUPERVISOR_HOME=/lab/projects/codex-supervisor

# Nível de log (INFO, DEBUG, etc.)
SUPERVISOR_LOG_LEVEL=INFO

# SQLite para persistência de sessão do Agents SDK
SESSION_DB_PATH=/lab/projects/codex-supervisor/state/agent_sessions.db

# Opcional: força um agent_session_id fixo (se vazio, deriva do TARGET_PROJECT_PATH)
AGENT_SESSION_ID=

# Opcional: auditoria compacta em logs/codex_mcp_audit.jsonl (1=true, 0=false)
SUPERVISOR_MCP_AUDIT=0

# Opcional: captura hints de threadId em warnings codex/event do SDK (fallback de baixo nivel)
SUPERVISOR_MCP_WARNING_CAPTURE=1

# Opcional: checkpoint/status no projeto-alvo (.supervisor/ + STATUS.md) (1=true, 0=false)
SUPERVISOR_PROJECT_JOURNAL=1

# Opcional: API HTTP local para integracao com GPT proprio
SUPERVISOR_API_HOST=127.0.0.1
SUPERVISOR_API_PORT=8787
SUPERVISOR_API_TOKEN=
SUPERVISOR_RUN_MAX_TURNS=2
SUPERVISOR_JOB_TIMEOUT_SECONDS=180
