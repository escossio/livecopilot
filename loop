#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOOP_BIN="$ROOT_DIR/codex_loop.sh"

usage() {
  cat <<'EOF'
Uso:
  /lab/projects/livecopilot/loop "minha tarefa aqui" [opcoes do codex_loop]
  /lab/projects/livecopilot/loop --file /caminho/tarefa.md [opcoes do codex_loop]
  /lab/projects/livecopilot/loop --stdin [opcoes do codex_loop]
  /lab/projects/livecopilot/loop --inspect
  /lab/projects/livecopilot/loop [comando operacional do codex_loop]

Exemplos:
  /lab/projects/livecopilot/loop "Corrigir bug X"
  /lab/projects/livecopilot/loop --file /tmp/tarefa.md
  cat tarefa.md | /lab/projects/livecopilot/loop --stdin
  /lab/projects/livecopilot/loop --inspect
  /lab/projects/livecopilot/loop --status
  /lab/projects/livecopilot/loop --next-action
  /lab/projects/livecopilot/loop --drain
EOF
}

if [[ ! -x "$LOOP_BIN" ]]; then
  echo "[erro] loop principal nao encontrado ou nao executavel: $LOOP_BIN" >&2
  exit 1
fi

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 2
fi

case "$1" in
  -h|--help)
    usage
    exit 0
    ;;
  --stdin)
    shift
    temp_file="$(mktemp /tmp/loop-stdin-XXXXXX.md)"
    cleanup_temp() {
      rm -f "$temp_file"
    }
    trap cleanup_temp EXIT
    cat > "$temp_file"
    if [[ ! -s "$temp_file" ]]; then
      echo "[erro] stdin vazio; nada foi enviado para a fila" >&2
      exit 2
    fi
    "$LOOP_BIN" --submit-file "$temp_file" "$@"
    exit $?
    ;;
  --inspect)
    "$LOOP_BIN" --status
    "$LOOP_BIN" --next-action
    exec "$LOOP_BIN" --last-summary
    ;;
  --file)
    if [[ $# -lt 2 || -z "${2:-}" ]]; then
      echo "[erro] informe o caminho do arquivo apos --file" >&2
      exit 2
    fi
    task_file="$2"
    shift 2
    exec "$LOOP_BIN" --submit-file "$task_file" "$@"
    ;;
  --*)
    exec "$LOOP_BIN" "$@"
    ;;
  *)
    task_text="$1"
    shift
    exec "$LOOP_BIN" --submit "$task_text" "$@"
    ;;
esac
